@page "/budget"
@inject IBudgetService BudgetSvc
@inject IRepository<FamilyMember> MemberRepo

<div class="page-container">
    <div class="page-header">
        <h2>📊 预算管理</h2>
        <button class="btn btn-primary" @onclick="StartAdd">+ 设置预算</button>
    </div>

    <div class="section">
        <div class="filter-bar">
            <label>年份:</label>
            <InputNumber @bind-Value="filterYear" @bind:after="LoadAll" />
 
            <label>月份:</label>
            <InputNumber @bind-Value="filterMonth" @bind:after="LoadAll" />
            <button class="btn btn-sm" @onclick="ResetMonth">本月</button>
        </div>

        @if (monthlyStatus.Count > 0)
        {
            <h3 class="section-title">📋 @filterYear 年 @filterMonth 月预算执行情况</h3>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>分类</th>
                        <th>预算金额</th>
                        <th>实际支出</th>
                        <th>剩余</th>
                        <th>使用率</th>
                        <th>状态</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in monthlyStatus)
                    {
                        var overspent = item.Status.Remaining < 0;
                        var warning = !overspent && item.Status.UsagePercent >= 80m;
                        <tr class="@(overspent ? "row-danger" : warning ? "row-warning" : "")">
                            <td><strong>@(string.IsNullOrEmpty(item.Budget.Category) ? "总预算" : item.Budget.Category)</strong></td>
                            <td class="amount">@item.Status.BudgetAmount.ToString("N2")</td>
                            <td class="amount">@item.Status.ActualExpense.ToString("N2")</td>
                            <td class="amount @(overspent ? "text-danger" : "")">
                                @item.Status.Remaining.ToString("N2")
                            </td>
                            <td>
                                <div class="progress-bar">
                                    <div class="progress-fill @(overspent ? "fill-danger" : warning ? "fill-warning" : "fill-normal")"
                                         style="width: @(Math.Min((double)item.Status.UsagePercent, 100))%"></div>
                                    <span class="progress-text">@item.Status.UsagePercent.ToString("F1")%</span>
                                </div>
                            </td>
                            <td>
                                @if (overspent)
                                { <span class="tag tag-red">超支</span> }
                                else if (warning)
                                { <span class="tag tag-orange">警戒</span> }
                                else
                                { <span class="tag tag-green">正常</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-row">@filterYear 年 @filterMonth 月暂无预算设置</div>
        }
    </div>

    <div class="section">
        <h3 class="section-title">📒 全部预算</h3>
        <table class="data-table">
            <thead>
                <tr><th>年月</th><th>分类</th><th>金额</th><th>成员</th><th>备注</th><th>操作</th></tr>
            </thead>
            <tbody>
                @foreach (var b in budgets)
                {
                    <tr>
                        <td>@b.Year-@b.Month.ToString("00")</td>
                        <td><strong>@(string.IsNullOrEmpty(b.Category) ? "总预算" : b.Category)</strong></td>
                        <td class="amount">@b.Amount.ToString("N2")</td>
                        <td>@GetMemberName(b.MemberId)</td>
                        <td>@(b.Notes ?? "-")</td>
                        <td class="actions">
                            <button class="btn btn-sm" @onclick="() => StartEdit(b)">编辑</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(b.Id)">删除</button>
                        </td>
                    </tr>
                }
                @if (budgets.Count == 0)
                {
                    <tr><td colspan="6" class="empty-row">暂无预算</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (showForm)
    {
        <div class="form-card">
            <h3>@(editing.Id > 0 ? "编辑预算" : "添加预算")</h3>
            <EditForm Model="editing" OnValidSubmit="Save">
                <div class="form-row">
                    <label>年份 *</label>
                    <InputNumber @bind-Value="editing.Year" />
                </div>
                <div class="form-row">
                    <label>月份 *</label>
                    <InputNumber @bind-Value="editing.Month" />
                </div>
                <div class="form-row">
                    <label>分类</label>
                    <InputText @bind-Value="editing.Category" placeholder="留空表示总预算;如:餐饮、教育" />
                </div>
                <div class="form-row">
                    <label>金额 *</label>
                    <InputNumber @bind-Value="editing.Amount" />
                </div>
                <div class="form-row">
                    <label>成员</label>
                    <InputSelect @bind-Value="editing.MemberId">
                        <option value="">家庭</option>
                        @foreach (var m in members)
                        {
                            <option value="@m.Id">@m.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="form-row">
                    <label>备注</label>
                    <InputTextArea @bind-Value="editing.Notes" />
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">保存</button>
                    <button type="button" class="btn" @onclick="CancelForm">取消</button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private List<FamilySuper.Core.Entities.Budget> budgets = new();
    private List<(FamilySuper.Core.Entities.Budget Budget, BudgetStatus Status)> monthlyStatus = new();
    private List<FamilyMember> members = new();
    private int filterYear = DateTime.UtcNow.Year;
    private int filterMonth = DateTime.UtcNow.Month;
    private bool showForm = false;
    private FamilySuper.Core.Entities.Budget editing = new();

    protected override async Task OnInitializedAsync()
    {
        members = await MemberRepo.GetAllAsync();
        await LoadAll();
    }

    private async Task LoadAll()
    {
        budgets = await BudgetSvc.GetBudgetsAsync(null, null);
        monthlyStatus = await BudgetSvc.GetMonthlyStatusAsync(filterYear, filterMonth);
    }

    private string GetMemberName(long? memberId)
        => memberId == null ? "家庭" : members.FirstOrDefault(m => m.Id == memberId)?.Name ?? "未知";

    private void ResetMonth()
    {
        filterYear = DateTime.UtcNow.Year;
        filterMonth = DateTime.UtcNow.Month;
        _ = LoadAll();
    }

    private void StartAdd()
    {
        editing = new FamilySuper.Core.Entities.Budget
        {
            Year = filterYear,
            Month = filterMonth,
            Amount = 0
        };
        showForm = true;
    }

    private void StartEdit(FamilySuper.Core.Entities.Budget b)
    {
        editing = new FamilySuper.Core.Entities.Budget
        {
            Id = b.Id,
            Year = b.Year,
            Month = b.Month,
            Category = b.Category,
            Amount = b.Amount,
            MemberId = b.MemberId,
            Notes = b.Notes
        };
        showForm = true;
    }

    private void CancelForm() => showForm = false;

    private async Task Save()
    {
        await BudgetSvc.AddOrUpdateAsync(editing);
        showForm = false;
        await LoadAll();
    }

    private async Task Delete(long id)
    {
        await BudgetSvc.DeleteAsync(id);
        await LoadAll();
    }
}

<style>
    .page-container { max-width: 1000px; margin: 0 auto; padding: 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .page-header h2 { margin: 0; color: #333; font-size: 22px; }
    .section { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 20px; }
    .section-title { margin: 0 0 12px; font-size: 16px; color: #333; }
    .filter-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
    .filter-bar label { font-size: 13px; color: #666; }
    .filter-bar input { width: 80px; padding: 6px 8px; border: 1px solid #ddd; border-radius: 6px; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .data-table th { text-align: left; padding: 10px 12px; background: #f5f7fa; color: #666; font-weight: 600; border-bottom: 2px solid #e0e0e0; }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid #eee; }
    .data-table .empty-row { text-align: center; color: #999; padding: 24px; }
    .data-table .actions { display: flex; gap: 6px; }
    .data-table .amount { text-align: right; font-variant-numeric: tabular-nums; }
    .row-warning { background: #fffbeb; }
    .row-danger { background: #fef2f2; }
    .text-danger { color: #d32f2f; font-weight: 600; }
    .tag { padding: 2px 8px; border-radius: 10px; font-size: 12px; font-weight: 600; }
    .tag-green { background: #e8f5e9; color: #2e7d32; }
    .tag-orange { background: #fff3e0; color: #ef6c00; }
    .tag-red { background: #ffebee; color: #c62828; }
    .progress-bar { position: relative; width: 140px; height: 18px; background: #f0f0f0; border-radius: 9px; overflow: hidden; }
    .progress-fill { height: 100%; transition: width 0.3s ease; }
    .fill-normal { background: linear-gradient(90deg, #66bb6a, #4caf50); }
    .fill-warning { background: linear-gradient(90deg, #ffa726, #fb8c00); }
    .fill-danger { background: linear-gradient(90deg, #ef5350, #d32f2f); }
    .progress-text { position: absolute; top: 0; left: 0; right: 0; text-align: center; font-size: 11px; line-height: 18px; color: #333; font-weight: 600; }
    .btn { padding: 6px 14px; border: 1px solid #ddd; border-radius: 6px; background: white; cursor: pointer; font-size: 13px; color: #555; }
    .btn:hover { background: #f0f4f8; }
    .btn-primary { background: #1976d2; color: white; border-color: #1976d2; }
    .btn-danger { color: #d32f2f; border-color: #ffcdd2; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .form-card { background: white; border-radius: 12px; padding: 20px; margin-top: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 2px solid #e3f2fd; }
    .form-card h3 { margin: 0 0 16px; font-size: 17px; }
    .form-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .form-row label { width: 80px; font-size: 14px; color: #555; }
    .form-row input, .form-row select, .form-row textarea { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
    .form-row textarea { min-height: 60px; resize: vertical; }
    .form-actions { display: flex; gap: 8px; margin-top: 16px; }
</style>
