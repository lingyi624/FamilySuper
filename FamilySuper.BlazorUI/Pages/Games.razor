@page "/games"
@inject Services.ModeStateContainer ModeState

<div class="page-container">
    <div class="page-header">
        <h2>🎮 互动游戏</h2>
    </div>
    <div class="empty-state">
        <div class="empty-icon">🎮</div>
        <h3>即将上线</h3>
        <p>我们正在为您准备有趣的互动游戏,敬请期待!</p>
        <div class="coming-soon-list">
            <div class="coming-soon-item">🧩 益智拼图</div>
            <div class="coming-soon-item">📖 成语接龙</div>
            <div class="coming-soon-item">🔢 数学闯关</div>
            <div class="coming-soon-item">🌍 地理探索</div>
        </div>
    </div>
</div>

<style>
    .page-container { max-width: 900px; margin: 0 auto; padding: 20px; }
    .page-header { margin-bottom: 24px; }
    .page-header h2 { margin: 0; color: #333; font-size: 22px; }
    .empty-state {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        background: white; border-radius: 16px; padding: 60px 40px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .empty-icon { font-size: 64px; margin-bottom: 20px; }
    .empty-state h3 { margin: 0 0 12px; color: #333; font-size: 24px; }
    .empty-state p { margin: 0 0 32px; color: #888; font-size: 15px; }
    .coming-soon-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; width: 100%; max-width: 500px; }
    .coming-soon-item {
        background: #f0f4f8; border-radius: 12px; padding: 16px; text-align: center;
        font-size: 15px; color: #555; font-weight: 500;
    }
</style>
