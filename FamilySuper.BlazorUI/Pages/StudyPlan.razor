@page "/study-plan"
@inject IStudyService StudySvc
@inject IRepository<FamilyMember> MemberRepo

<div class="page-container">
    <div class="page-header">
        <h2>📚 学习计划</h2>
        <button class="btn btn-primary" @onclick="StartAddPlan">+ 新建计划</button>
    </div>

    <div class="section">
        <div class="filter-bar">
            <label>成员:</label>
            <select @bind="filterMemberId" @bind:after="LoadPlans">
                <option value="">全部</option>
                @foreach (var m in members)
                {
                    <option value="@m.Id">@m.Name</option>
                }
            </select>
            <label class="checkbox-label">
                <InputCheckbox @bind-Value="showInactive" />
                <span>显示已停用</span>
            </label>
        </div>
        <table class="data-table">
            <thead>
                <tr><th>科目</th><th>成员</th><th>目标</th><th>每周时长</th><th>进度</th><th>起止</th><th>操作</th></tr>
            </thead>
            <tbody>
                @foreach (var p in plans)
                {
                    <tr>
                        <td><strong>@p.Subject</strong></td>
                        <td>@GetMemberName(p.MemberId)</td>
                        <td>@(p.Goal ?? "-")</td>
                        <td>@p.TargetHoursPerWeek 小时</td>
                        <td>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: @p.ProgressPercent%"></div>
                                <span class="progress-text">@p.ProgressPercent%</span>
                            </div>
                        </td>
                        <td>
                            @p.StartDate.ToString("yyyy-MM-dd")
                            @(p.EndDate == null ? " ~ 长期" : $" ~ {p.EndDate:yyyy-MM-dd}")
                        </td>
                        <td class="actions">
                            <button class="btn btn-sm" @onclick="() => StartLog(p)">记录</button>
                            <button class="btn btn-sm" @onclick="() => StartEditPlan(p)">编辑</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeletePlan(p.Id)">删除</button>
                        </td>
                    </tr>
                }
                @if (plans.Count == 0)
                {
                    <tr><td colspan="7" class="empty-row">暂无学习计划</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (showPlanForm)
    {
        <div class="form-card">
            <h3>@(editingPlan.Id > 0 ? "编辑学习计划" : "新建学习计划")</h3>
            <EditForm Model="editingPlan" OnValidSubmit="SavePlan">
                <div class="form-row"><label>科目 *</label><InputText @bind-Value="editingPlan.Subject" placeholder="如:数学、英语" /></div>
                <div class="form-row">
                    <label>成员</label>
                    <InputSelect @bind-Value="editingPlan.MemberId">
                        <option value="">请选择</option>
                        @foreach (var m in members)
                        {
                            <option value="@m.Id">@m.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="form-row"><label>学习目标</label><InputText @bind-Value="editingPlan.Goal" /></div>
                <div class="form-row"><label>每周目标时长(小时)</label><InputNumber @bind-Value="editingPlan.TargetHoursPerWeek" /></div>
                <div class="form-row"><label>开始日期</label><InputDate @bind-Value="editingPlan.StartDate" /></div>
                <div class="form-row"><label>结束日期</label><InputDate @bind-Value="editingPlan.EndDate" /></div>
                <div class="form-row"><label>备注</label><InputTextArea @bind-Value="editingPlan.Notes" /></div>
                <div class="form-row">
                    <label class="checkbox-label">
                        <InputCheckbox @bind-Value="editingPlan.IsActive" />
                        <span>启用此计划</span>
                    </label>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">保存</button>
                    <button type="button" class="btn" @onclick="CancelPlanForm">取消</button>
                </div>
            </EditForm>
        </div>
    }

    @if (showLogForm)
    {
        <div class="form-card">
            <h3>记录学习 - @loggingPlan.Subject</h3>
            <EditForm Model="editingLog" OnValidSubmit="SaveLog">
                <div class="form-row"><label>学习日期</label><InputDate @bind-Value="editingLog.StudyDate" /></div>
                <div class="form-row"><label>时长(分钟)</label><InputNumber @bind-Value="editingLog.DurationMinutes" /></div>
                <div class="form-row">
                    <label>完成情况</label>
                    <InputSelect @bind-Value="editingLog.Completion">
                        <option value="completed">已完成</option>
                        <option value="partial">部分完成</option>
                        <option value="skipped">未完成</option>
                    </InputSelect>
                </div>
                <div class="form-row"><label>学习内容</label><InputTextArea @bind-Value="editingLog.Content" /></div>
                <div class="form-row"><label>备注</label><InputTextArea @bind-Value="editingLog.Notes" /></div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">保存记录</button>
                    <button type="button" class="btn" @onclick="CancelLogForm">取消</button>
                </div>
            </EditForm>
        </div>
    }

    <div class="section">
        <div class="report-header">
            <h3>📈 学习报告</h3>
            <div class="report-controls">
                <label>从:</label><InputDate @bind-Value="reportFrom" />
                <label>到:</label><InputDate @bind-Value="reportTo" />
                <button class="btn btn-sm btn-primary" @onclick="LoadReport">生成</button>
            </div>
        </div>
        @if (report is not null)
        {
            <div class="report-summary">
                <div class="stat-card">
                    <div class="stat-value">@report.TotalMinutes</div>
                    <div class="stat-label">总学习时长(分钟)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">@report.TotalSessions</div>
                    <div class="stat-label">学习次数</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">@report.CompletionRate.ToString("F1")%</div>
                    <div class="stat-label">完成率</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">@((report.TotalMinutes / 60.0).ToString("F1"))</div>
                    <div class="stat-label">总时长(小时)</div>
                </div>
            </div>
            @if (report.MinutesBySubject.Count > 0)
            {
                <h4 class="sub-title">按科目分布</h4>
                <div class="bar-chart">
                    @foreach (var kv in report.MinutesBySubject.OrderByDescending(x => x.Value))
                    {
                        var max = report.MinutesBySubject.Values.Max();
                        var pct = max > 0 ? (kv.Value * 100.0 / max) : 0;
                        <div class="bar-row">
                            <span class="bar-label">@kv.Key</span>
                            <div class="bar-track"><div class="bar-fill" style="width: @pct%"></div></div>
                            <span class="bar-value">@kv.Value 分</span>
                        </div>
                    }
                </div>
            }
            @if (report.RecentLogs.Count > 0)
            {
                <h4 class="sub-title">最近学习记录</h4>
                <table class="data-table">
                    <thead><tr><th>日期</th><th>时长</th><th>完成情况</th><th>内容</th></tr></thead>
                    <tbody>
                        @foreach (var l in report.RecentLogs)
                        {
                            <tr>
                                <td>@l.StudyDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@l.DurationMinutes 分</td>
                                <td><span class="tag @(l.Completion == "completed" ? "tag-green" : l.Completion == "partial" ? "tag-orange" : "tag-red")">@l.Completion</span></td>
                                <td>@(l.Content ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-row">该时段暂无学习记录</div>
            }
        }
    </div>
</div>

@code {
    private List<FamilySuper.Core.Entities.StudyPlan> plans = new();
    private List<FamilyMember> members = new();
    private long? filterMemberId;
    private bool showInactive = false;
    private bool showPlanForm = false;
    private bool showLogForm = false;
    private FamilySuper.Core.Entities.StudyPlan editingPlan = new();
    private FamilySuper.Core.Entities.StudyPlan loggingPlan = new();
    private FamilySuper.Core.Entities.StudyLog editingLog = new();
    private StudyReport? report;
    private DateTime reportFrom = DateTime.UtcNow.AddDays(-30);
    private DateTime reportTo = DateTime.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        members = await MemberRepo.GetAllAsync();
        await LoadPlans();
        await LoadReport();
    }

    private async Task LoadPlans()
    {
        plans = await StudySvc.GetPlansAsync(filterMemberId, !showInactive);
    }

    private string GetMemberName(long? id)
        => id == null ? "未指定" : members.FirstOrDefault(m => m.Id == id)?.Name ?? "未知";

    private void StartAddPlan()
    {
        editingPlan = new FamilySuper.Core.Entities.StudyPlan { StartDate = DateTime.UtcNow, IsActive = true, TargetHoursPerWeek = 5 };
        showPlanForm = true;
    }

    private void StartEditPlan(FamilySuper.Core.Entities.StudyPlan p)
    {
        editingPlan = new FamilySuper.Core.Entities.StudyPlan
        {
            Id = p.Id, MemberId = p.MemberId, Subject = p.Subject, Goal = p.Goal,
            TargetHoursPerWeek = p.TargetHoursPerWeek, ProgressPercent = p.ProgressPercent,
            StartDate = p.StartDate, EndDate = p.EndDate, IsActive = p.IsActive, Notes = p.Notes
        };
        showPlanForm = true;
    }

    private void CancelPlanForm() => showPlanForm = false;

    private async Task SavePlan()
    {
        if (editingPlan.Id > 0) await StudySvc.UpdatePlanAsync(editingPlan);
        else await StudySvc.AddPlanAsync(editingPlan);
        showPlanForm = false;
        await LoadPlans();
    }

    private async Task DeletePlan(long id)
    {
        await StudySvc.DeletePlanAsync(id);
        await LoadPlans();
    }

    private void StartLog(FamilySuper.Core.Entities.StudyPlan p)
    {
        loggingPlan = p;
        editingLog = new FamilySuper.Core.Entities.StudyLog
        {
            StudyPlanId = p.Id,
            MemberId = p.MemberId,
            StudyDate = DateTime.UtcNow,
            DurationMinutes = 30,
            Completion = "completed"
        };
        showLogForm = true;
    }

    private void CancelLogForm() => showLogForm = false;

    private async Task SaveLog()
    {
        await StudySvc.LogStudyAsync(editingLog);
        showLogForm = false;
        await LoadPlans();
        await LoadReport();
    }

    private async Task LoadReport()
    {
        report = await StudySvc.GenerateReportAsync(filterMemberId, reportFrom, reportTo);
    }
}

<style>
    .page-container { max-width: 1000px; margin: 0 auto; padding: 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .page-header h2 { margin: 0; color: #333; font-size: 22px; }
    .section { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 20px; }
    .section h3 { margin: 0 0 12px; font-size: 16px; color: #333; }
    .filter-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
    .filter-bar label { font-size: 13px; color: #666; }
    .filter-bar select { padding: 6px 12px; border: 1px solid #ddd; border-radius: 6px; }
    .checkbox-label { display: flex; align-items: center; gap: 4px; cursor: pointer; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .data-table th { text-align: left; padding: 10px 12px; background: #f5f7fa; color: #666; font-weight: 600; border-bottom: 2px solid #e0e0e0; }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid #eee; }
    .data-table .empty-row { text-align: center; color: #999; padding: 24px; }
    .data-table .actions { display: flex; gap: 6px; }
    .progress-bar { position: relative; width: 120px; height: 18px; background: #f0f0f0; border-radius: 9px; overflow: hidden; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #66bb6a, #4caf50); }
    .progress-text { position: absolute; top: 0; left: 0; right: 0; text-align: center; font-size: 11px; line-height: 18px; color: #333; font-weight: 600; }
    .tag { padding: 2px 8px; border-radius: 10px; font-size: 12px; font-weight: 600; }
    .tag-green { background: #e8f5e9; color: #2e7d32; }
    .tag-orange { background: #fff3e0; color: #ef6c00; }
    .tag-red { background: #ffebee; color: #c62828; }
    .btn { padding: 6px 14px; border: 1px solid #ddd; border-radius: 6px; background: white; cursor: pointer; font-size: 13px; color: #555; }
    .btn:hover { background: #f0f4f8; }
    .btn-primary { background: #1976d2; color: white; border-color: #1976d2; }
    .btn-danger { color: #d32f2f; border-color: #ffcdd2; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .form-card { background: white; border-radius: 12px; padding: 20px; margin-top: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 2px solid #e3f2fd; }
    .form-card h3 { margin: 0 0 16px; font-size: 17px; }
    .form-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .form-row label { width: 120px; font-size: 14px; color: #555; }
    .form-row input, .form-row select, .form-row textarea { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
    .form-row textarea { min-height: 60px; resize: vertical; }
    .form-actions { display: flex; gap: 8px; margin-top: 16px; }
    .report-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .report-controls { display: flex; align-items: center; gap: 6px; font-size: 13px; }
    .report-controls input { padding: 4px 8px; border: 1px solid #ddd; border-radius: 6px; }
    .report-summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
    .stat-card { background: #f5f7fa; border-radius: 8px; padding: 16px; text-align: center; }
    .stat-value { font-size: 24px; font-weight: 700; color: #1976d2; }
    .stat-label { font-size: 12px; color: #888; margin-top: 4px; }
    .sub-title { font-size: 14px; color: #555; margin: 16px 0 8px; }
    .bar-chart { display: flex; flex-direction: column; gap: 8px; }
    .bar-row { display: flex; align-items: center; gap: 8px; }
    .bar-label { width: 80px; font-size: 13px; color: #555; }
    .bar-track { flex: 1; height: 22px; background: #f0f0f0; border-radius: 11px; overflow: hidden; }
    .bar-fill { height: 100%; background: linear-gradient(90deg, #42a5f5, #1976d2); }
    .bar-value { width: 70px; font-size: 12px; color: #666; text-align: right; }
</style>
