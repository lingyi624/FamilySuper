@page "/bill"
@inject IBillService BillSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using FamilySuper.Host.WPF.Components.Dialogs

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>🧾</span>
                        <span>账单提醒</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartAdd" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        添加账单
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (dueSoon.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4">
                        <div class="d-flex justify-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span><MudIcon Icon="@Icons.Material.Filled.Alarm" /></span>
                                <span>即将到期 (@dueSoon.Count)</span>
                            </div>
                        </div>
                    </MudAlert>
                    <div class="reminder-list">
                        @foreach (var b in dueSoon)
                        {
                            var days = (b.NextDueDate - DateTime.UtcNow).Days;
                            <MudCard 
                                Elevation="2" 
                                Class="@(days < 0 ? "overdue-card" : days <= 2 ? "urgent-card" : "reminder-card")">
                                <MudCardContent>
                                    <div class="d-flex justify-between align-items-center">
                                        <div>
                                            <MudText Typo="Typo.h6" FontWeight="FontWeight.Bold">@b.Name</MudText>
                                            <MudText Typo="Typo.body2" Class="text-gray-500">
                                                ¥@b.Amount.ToString("N2") · @(b.Category ?? "未分类") ·
                                                @(days < 0 ? $"已逾期 {-days} 天" : days == 0 ? "今天到期" : $"{days} 天后到期")
                                            </MudText>
                                        </div>
                                        <MudButton Color="Color.Success" Size="Size.Small" OnClick="() => MarkPaid(b.Id)" Variant="Variant.Filled">
                                            标记已付
                                        </MudButton>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        }
                    </div>
                }

                <MudCheckBox @bind-Value="showInactive" Label="显示已停用" OnChange="LoadAll" Class="mt-4 mb-4" />

                <MudTable Items="bills" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>账单名称</MudTh>
                        <MudTh>金额</MudTh>
                        <MudTh>分类</MudTh>
                        <MudTh>周期</MudTh>
                        <MudTh>下次到期</MudTh>
                        <MudTh>状态</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText FontWeight="FontWeight.Bold">@context.Name</MudText></MudTd>
                        <MudTd Class="text-right"><MudText Typo="Typo.body2" FontWeight="FontWeight.Bold">¥@context.Amount.ToString("N2")</MudText></MudTd>
                        <MudTd>@(context.Category ?? "-")</MudTd>
                        <MudTd>@GetCycleName(context.CycleType)</MudTd>
                        <MudTd>@context.NextDueDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@GetStatusColor(context)" Size="Size.Small">
                                @GetStatusLabel(context)
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                @if (!context.IsPaid)
                                {
                                    <MudButton Color="Color.Success" OnClick="() => MarkPaid(context.Id)">已付</MudButton>
                                }
                                <MudButton Color="Color.Info" OnClick="() => StartEdit(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="() => Delete(context.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无账单</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(editing.Id > 0 ? "编辑账单" : "添加账单")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm @ref="_form" @bind-IsValid="_isFormValid" Model="editing">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="名称 *" @bind-Value="editing.Name" Required="true" Placeholder="如:电费、信用卡还款" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField Label="金额 *" @bind-Value="editing.Amount" T="decimal" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="分类" @bind-Value="editing.Category" Placeholder="水电煤/物业/信用卡" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="周期" @bind-Value="editing.CycleType" T="FamilySuper.Core.Enums.BillCycleType">
                                    <MudSelectItem T="FamilySuper.Core.Enums.BillCycleType" Value="FamilySuper.Core.Enums.BillCycleType.Once">一次性</MudSelectItem>
                                    <MudSelectItem T="FamilySuper.Core.Enums.BillCycleType" Value="FamilySuper.Core.Enums.BillCycleType.Monthly">每月</MudSelectItem>
                                    <MudSelectItem T="FamilySuper.Core.Enums.BillCycleType" Value="FamilySuper.Core.Enums.BillCycleType.Quarterly">每季</MudSelectItem>
                                    <MudSelectItem T="FamilySuper.Core.Enums.BillCycleType" Value="FamilySuper.Core.Enums.BillCycleType.Yearly">每年</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="开始日期" @bind-Date="startDateValue" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="备注" @bind-Value="editing.Notes" Multiline="true" Rows="2" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudCheckBox @bind-Value="editing.IsActive" Label="启用此账单" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(!_isFormValid)" Variant="Variant.Filled">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelForm" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private MudForm _form = default!;
    private bool _isFormValid;
    private List<FamilySuper.Core.Entities.BillReminder> bills = new();
    private List<FamilySuper.Core.Entities.BillReminder> dueSoon = new();
    private bool showInactive = false;
    private bool showForm = false;
    private FamilySuper.Core.Entities.BillReminder editing = new();
    private DateTime? startDateValue;

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        bills = await BillSvc.GetBillsAsync(showInactive ? null : true);
        dueSoon = await BillSvc.GetDueSoonAsync(7);
    }

    private string GetCycleName(FamilySuper.Core.Enums.BillCycleType c) => c switch
    {
        FamilySuper.Core.Enums.BillCycleType.Once => "一次性",
        FamilySuper.Core.Enums.BillCycleType.Monthly => "每月",
        FamilySuper.Core.Enums.BillCycleType.Quarterly => "每季",
        FamilySuper.Core.Enums.BillCycleType.Yearly => "每年",
        _ => c.ToString()
    };

    private void StartAdd()
    {
        editing = new FamilySuper.Core.Entities.BillReminder
        {
            StartDate = DateTime.UtcNow,
            IsActive = true,
            Amount = 0
        };
        startDateValue = editing.StartDate;
        showForm = true;
    }

    private void StartEdit(FamilySuper.Core.Entities.BillReminder b)
    {
        editing = new FamilySuper.Core.Entities.BillReminder
        {
            Id = b.Id, Name = b.Name, Amount = b.Amount, Category = b.Category,
            CycleType = b.CycleType, StartDate = b.StartDate, IsActive = b.IsActive,
            MemberId = b.MemberId, Notes = b.Notes
        };
        startDateValue = b.StartDate;
        showForm = true;
    }

    private void CancelForm() => showForm = false;

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_isFormValid) return;
        try
        {
            if (startDateValue.HasValue) editing.StartDate = startDateValue.Value;
            if (editing.Id > 0)
            {
                await BillSvc.UpdateBillAsync(editing);
                Snackbar.Add("账单已更新", Severity.Success);
            }
            else
            {
                await BillSvc.AddBillAsync(editing);
                Snackbar.Add("账单已添加", Severity.Success);
            }
            showForm = false;
            await LoadAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task Delete(long id)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("确认删除");
        var result = await dialog.Result;
        if (result.Canceled) return;

        try
        {
            await BillSvc.DeleteBillAsync(id);
            await LoadAll();
            Snackbar.Add("账单已删除", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task MarkPaid(long id)
    {
        try
        {
            await BillSvc.MarkPaidAsync(id);
            await LoadAll();
            Snackbar.Add("已标记为已付", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"操作失败: {ex.Message}", Severity.Error);
        }
    }

    private static Color GetStatusColor(FamilySuper.Core.Entities.BillReminder b)
    {
        if (b.IsPaid) return Color.Default;
        if (b.NextDueDate < DateTime.UtcNow) return Color.Error;
        return Color.Success;
    }

    private static string GetStatusLabel(FamilySuper.Core.Entities.BillReminder b)
    {
        if (b.IsPaid) return "已付";
        if (b.NextDueDate < DateTime.UtcNow) return "逾期";
        return "待付";
    }
}

<style>
    .reminder-list { display: flex; flex-direction: column; gap: 8px; }
    .reminder-card { border-left: 4px solid #ffb300; }
    .urgent-card { border-left: 4px solid #ff7043; background: #fff8e1; }
    .overdue-card { border-left: 4px solid #ef5350; background: #ffebee; }
</style>
