@page "/bill"
@inject IBillService BillSvc

<div class="page-container">
    <div class="page-header">
        <h2>🧾 账单提醒</h2>
        <button class="btn btn-primary" @onclick="StartAdd">+ 添加账单</button>
    </div>

    @if (dueSoon.Count > 0)
    {
        <div class="section reminder-section">
            <h3>⏰ 即将到期 (@dueSoon.Count)</h3>
            <div class="reminder-list">
                @foreach (var b in dueSoon)
                {
                    var days = (b.NextDueDate - DateTime.UtcNow).Days;
                    <div class="reminder-card @(days < 0 ? "overdue" : days <= 2 ? "urgent" : "")">
                        <div class="reminder-info">
                            <strong>@b.Name</strong>
                            <span class="reminder-meta">
                                ¥@b.Amount.ToString("N2") · @(b.Category ?? "未分类") ·
                                @(days < 0 ? $"已逾期 {-days} 天" : days == 0 ? "今天到期" : $"{days} 天后到期")
                            </span>
                        </div>
                        <button class="btn btn-sm btn-success" @onclick="() => MarkPaid(b.Id)">标记已付</button>
                    </div>
                }
            </div>
        </div>
    }

    <div class="section">
        <div class="filter-bar">
            <label class="checkbox-label">
                <InputCheckbox @bind-Value="showInactive" />
                <span>显示已停用</span>
            </label>
        </div>
        <table class="data-table">
            <thead>
                <tr><th>账单名称</th><th>金额</th><th>分类</th><th>周期</th><th>下次到期</th><th>状态</th><th>操作</th></tr>
            </thead>
            <tbody>
                @foreach (var b in bills)
                {
                    <tr>
                        <td><strong>@b.Name</strong></td>
                        <td class="amount">¥@b.Amount.ToString("N2")</td>
                        <td>@(b.Category ?? "-")</td>
                        <td>@GetCycleName(b.CycleType)</td>
                        <td>@b.NextDueDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (b.IsPaid)
                            { <span class="tag tag-gray">已付</span> }
                            else if (b.NextDueDate < DateTime.UtcNow)
                            { <span class="tag tag-red">逾期</span> }
                            else
                            { <span class="tag tag-green">待付</span> }
                        </td>
                        <td class="actions">
                            @if (!b.IsPaid)
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => MarkPaid(b.Id)">已付</button>
                            }
                            <button class="btn btn-sm" @onclick="() => StartEdit(b)">编辑</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(b.Id)">删除</button>
                        </td>
                    </tr>
                }
                @if (bills.Count == 0)
                {
                    <tr><td colspan="7" class="empty-row">暂无账单</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (showForm)
    {
        <div class="form-card">
            <h3>@(editing.Id > 0 ? "编辑账单" : "添加账单")</h3>
            <EditForm Model="editing" OnValidSubmit="Save">
                <div class="form-row"><label>名称 *</label><InputText @bind-Value="editing.Name" placeholder="如:电费、信用卡还款" /></div>
                <div class="form-row"><label>金额 *</label><InputNumber @bind-Value="editing.Amount" /></div>
                <div class="form-row"><label>分类</label><InputText @bind-Value="editing.Category" placeholder="水电煤/物业/信用卡" /></div>
                <div class="form-row">
                    <label>周期</label>
                    <InputSelect @bind-Value="editing.CycleType">
                        <option value="Once">一次性</option>
                        <option value="Monthly">每月</option>
                        <option value="Quarterly">每季</option>
                        <option value="Yearly">每年</option>
                    </InputSelect>
                </div>
                <div class="form-row"><label>开始日期</label><InputDate @bind-Value="editing.StartDate" /></div>
                <div class="form-row"><label>备注</label><InputTextArea @bind-Value="editing.Notes" /></div>
                <div class="form-row">
                    <label class="checkbox-label">
                        <InputCheckbox @bind-Value="editing.IsActive" />
                        <span>启用此账单</span>
                    </label>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">保存</button>
                    <button type="button" class="btn" @onclick="CancelForm">取消</button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private List<FamilySuper.Core.Entities.BillReminder> bills = new();
    private List<FamilySuper.Core.Entities.BillReminder> dueSoon = new();
    private bool showInactive = false;
    private bool showForm = false;
    private FamilySuper.Core.Entities.BillReminder editing = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        bills = await BillSvc.GetBillsAsync(showInactive ? null : true);
        dueSoon = await BillSvc.GetDueSoonAsync(7);
    }

    private string GetCycleName(FamilySuper.Core.Enums.BillCycleType c) => c switch
    {
        FamilySuper.Core.Enums.BillCycleType.Once => "一次性",
        FamilySuper.Core.Enums.BillCycleType.Monthly => "每月",
        FamilySuper.Core.Enums.BillCycleType.Quarterly => "每季",
        FamilySuper.Core.Enums.BillCycleType.Yearly => "每年",
        _ => c.ToString()
    };

    private void StartAdd()
    {
        editing = new FamilySuper.Core.Entities.BillReminder
        {
            StartDate = DateTime.UtcNow,
            IsActive = true,
            Amount = 0
        };
        showForm = true;
    }

    private void StartEdit(FamilySuper.Core.Entities.BillReminder b)
    {
        editing = new FamilySuper.Core.Entities.BillReminder
        {
            Id = b.Id, Name = b.Name, Amount = b.Amount, Category = b.Category,
            CycleType = b.CycleType, StartDate = b.StartDate, IsActive = b.IsActive,
            MemberId = b.MemberId, Notes = b.Notes
        };
        showForm = true;
    }

    private void CancelForm() => showForm = false;

    private async Task Save()
    {
        if (editing.Id > 0) await BillSvc.UpdateBillAsync(editing);
        else await BillSvc.AddBillAsync(editing);
        showForm = false;
        await LoadAll();
    }

    private async Task Delete(long id)
    {
        await BillSvc.DeleteBillAsync(id);
        await LoadAll();
    }

    private async Task MarkPaid(long id)
    {
        await BillSvc.MarkPaidAsync(id);
        await LoadAll();
    }
}

<style>
    .page-container { max-width: 1000px; margin: 0 auto; padding: 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .page-header h2 { margin: 0; color: #333; font-size: 22px; }
    .section { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 20px; }
    .section h3 { margin: 0 0 12px; font-size: 16px; color: #333; }
    .filter-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
    .checkbox-label { display: flex; align-items: center; gap: 4px; cursor: pointer; font-size: 13px; color: #666; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .data-table th { text-align: left; padding: 10px 12px; background: #f5f7fa; color: #666; font-weight: 600; border-bottom: 2px solid #e0e0e0; }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid #eee; }
    .data-table .empty-row { text-align: center; color: #999; padding: 24px; }
    .data-table .actions { display: flex; gap: 6px; }
    .data-table .amount { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; }
    .tag { padding: 2px 8px; border-radius: 10px; font-size: 12px; font-weight: 600; }
    .tag-green { background: #e8f5e9; color: #2e7d32; }
    .tag-gray { background: #f5f5f5; color: #999; }
    .tag-red { background: #ffebee; color: #c62828; }
    .btn { padding: 6px 14px; border: 1px solid #ddd; border-radius: 6px; background: white; cursor: pointer; font-size: 13px; color: #555; }
    .btn:hover { background: #f0f4f8; }
    .btn-primary { background: #1976d2; color: white; border-color: #1976d2; }
    .btn-danger { color: #d32f2f; border-color: #ffcdd2; }
    .btn-success { background: #4caf50; color: white; border-color: #4caf50; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .form-card { background: white; border-radius: 12px; padding: 20px; margin-top: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 2px solid #e3f2fd; }
    .form-card h3 { margin: 0 0 16px; font-size: 17px; }
    .form-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .form-row label { width: 80px; font-size: 14px; color: #555; }
    .form-row input, .form-row select, .form-row textarea { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
    .form-row textarea { min-height: 60px; resize: vertical; }
    .form-actions { display: flex; gap: 8px; margin-top: 16px; }
    .reminder-section { border: 2px solid #fff3cd; background: #fffbeb; }
    .reminder-list { display: flex; flex-direction: column; gap: 8px; }
    .reminder-card { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: white; border-radius: 8px; border: 1px solid #ffe082; }
    .reminder-card.overdue { border-color: #ef9a9a; background: #fef2f2; }
    .reminder-card.urgent { border-color: #ffab91; background: #fff3e0; }
    .reminder-info { display: flex; flex-direction: column; gap: 2px; }
    .reminder-meta { font-size: 12px; color: #888; }
</style>
