@page "/health"
@inject IHealthService HealthSvc
@inject IRepository<FamilyMember> MemberRepo
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using FamilySuper.Host.WPF.Components.Dialogs
@using FamilySuper.Core.Enums

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>❤️</span>
                        <span>健康档案</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartAdd" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        添加记录
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Class="mb-4">
                    <MudItem xs="12" sm="6">
                        <MudSelect 
                            Label="成员" 
                            @bind-Value="filterMemberId" 
                            T="long?" 
                            Placeholder="全部"
                            OnChange="LoadRecords">
                            <MudSelectItem T="long?" Value="null">全部</MudSelectItem>
                            @foreach (var m in members)
                            {
                                <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect 
                            Label="类型" 
                            @bind-Value="filterType" 
                            T="HealthRecordType?" 
                            Placeholder="全部"
                            OnChange="LoadRecords">
                            <MudSelectItem T="HealthRecordType?" Value="null">全部</MudSelectItem>
                            @foreach (var t in Enum.GetValues<HealthRecordType>())
                            {
                                <MudSelectItem T="HealthRecordType?" Value="t">@t.ToChinese()</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                <MudTable Items="records" T="HealthRecord" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>标题</MudTh>
                        <MudTh>类型</MudTh>
                        <MudTh>日期</MudTh>
                        <MudTh>医院</MudTh>
                        <MudTh>医生</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Title</MudTd>
                        <MudTd>
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.RecordType.ToChinese()</MudChip>
                        </MudTd>
                        <MudTd>@(context.RecordDate?.ToString("yyyy-MM-dd") ?? "-")</MudTd>
                        <MudTd>@(context.Hospital ?? "-")</MudTd>
                        <MudTd>@(context.Doctor ?? "-")</MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                <MudButton Color="Color.Info" OnClick="() => StartEdit(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="() => Delete(context.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无记录</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(editing.Id > 0 ? "编辑记录" : "添加记录")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm Model="editing" @ref="_form" @bind-IsValid="_isFormValid">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="标题 *" @bind-Value="editing.Title" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="类型" @bind-Value="editing.RecordType" T="HealthRecordType">
                                    @foreach (var t in Enum.GetValues<HealthRecordType>())
                                    {
                                        <MudSelectItem T="HealthRecordType" Value="t">@t.ToChinese()</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="成员" @bind-Value="editing.MemberId" T="long?">
                                    <MudSelectItem T="long?" Value="null">无</MudSelectItem>
                                    @foreach (var m in members)
                                    {
                                        <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="日期" @bind-Date="editing.RecordDate" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="医院" @bind-Value="editing.Hospital" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="医生" @bind-Value="editing.Doctor" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="内容" @bind-Value="editing.Content" Multiline="true" Rows="3" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(!_isFormValid)" Variant="Variant.Filled">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="Cancel" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private MudForm _form = default!;
    private bool _isFormValid;
    private List<HealthRecord> records = new();
    private List<FamilyMember> members = new();
    private HealthRecord editing = new();
    private bool showForm;
    private long? filterMemberId;
    private HealthRecordType? filterType;

    protected override async Task OnInitializedAsync()
    {
        members = await MemberRepo.GetAllAsync();
        await LoadRecords();
    }

    private async Task LoadRecords()
    {
        records = await HealthSvc.GetRecordsAsync(filterMemberId, filterType);
    }

    private void StartAdd()
    {
        editing = new HealthRecord { RecordDate = DateTime.UtcNow, CreatedAt = DateTime.UtcNow };
        showForm = true;
    }

    private void StartEdit(HealthRecord r)
    {
        editing = new HealthRecord
        {
            Id = r.Id, Title = r.Title, RecordType = r.RecordType, Content = r.Content,
            RecordDate = r.RecordDate, Doctor = r.Doctor, Hospital = r.Hospital,
            MemberId = r.MemberId, Remark = r.Remark, CreatedAt = r.CreatedAt
        };
        showForm = true;
    }

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_isFormValid) return;
        try
        {
            if (editing.Id > 0)
            {
                await HealthSvc.UpdateAsync(editing);
                Snackbar.Add("健康记录已更新", Severity.Success);
            }
            else
            {
                await HealthSvc.AddAsync(editing);
                Snackbar.Add("健康记录已添加", Severity.Success);
            }
            showForm = false;
            await LoadRecords();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => showForm = false;

    private async Task Delete(long id)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("确认删除");
        var result = await dialog.Result;
        if (result.Canceled) return;

        try
        {
            await HealthSvc.DeleteAsync(id);
            await LoadRecords();
            Snackbar.Add("健康记录已删除", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
        }
    }
}
