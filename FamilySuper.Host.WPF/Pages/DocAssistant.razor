@page "/doc-assistant"
@inject IAgentService Agent
@inject Services.ModeStateContainer ModeState
@inject IJSRuntime JSRuntime

<MudGrid Class="max-w-4xl mx-auto">
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>📝</span>
                        <span>文档助手</span>
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <div class="mb-4">
                    <MudText Typo="Typo.body2" Class="text-gray-500 mb-2">选择操作:</MudText>
                    <MudSelect Label="操作类型" @bind-Value="selectedAction" T="string" Class="w-full">
                        <MudSelectItem T="string" Value="@("summarize")">📋 智能摘要</MudSelectItem>
                        <MudSelectItem T="string" Value="@("translate")">🌐 翻译</MudSelectItem>
                        <MudSelectItem T="string" Value="@("polish")">✨ 润色</MudSelectItem>
                        <MudSelectItem T="string" Value="@("expand")">📖 扩写</MudSelectItem>
                        <MudSelectItem T="string" Value="@("rewrite")">🔄 改写</MudSelectItem>
                        <MudSelectItem T="string" Value="@("extract")">📌 提取要点</MudSelectItem>
                    </MudSelect>
                </div>

                <div class="mb-4">
                    <MudText Typo="Typo.body2" Class="text-gray-500 mb-2">输入文档内容:</MudText>
                    <MudTextField 
                        @bind-Value="inputText" 
                        Label="输入文本"
                        Multiline="true" 
                        Rows="12"
                        Placeholder="粘贴或输入需要处理的文本内容..."
                        Class="w-full" />
                </div>

                <div class="mb-4">
                    <MudText Typo="Typo.body2" Class="text-gray-500 mb-2">处理结果:</MudText>
                    <MudCard Elevation="0" Class="bg-gray-50 border">
                        <MudCardContent>
                            @if (loading)
                            {
                                <div class="text-center py-8">
                                    <MudProgressCircular Size="Size.Small" Class="mb-2" />
                                    <MudText Typo="Typo.body2" Class="text-gray-500">处理中...</MudText>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(outputText))
                            {
                                <MudText Typo="Typo.body1" Class="whitespace-pre-wrap" Style="line-height: 1.7;">@outputText</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="text-gray-400 text-center py-8">处理结果将显示在这里</MudText>
                            }
                        </MudCardContent>
                    </MudCard>
                </div>

                <div class="form-actions">
                    <MudButton Color="Color.Primary" OnClick="Process" Disabled="@IsProcessDisabled" Variant="Variant.Filled">
                        @(loading ? "处理中..." : "开始处理")
                    </MudButton>
                    <MudButton Color="Color.Default" OnClick="Clear" Class="ml-2">清空</MudButton>
                    <MudButton Color="Color.Default" OnClick="CopyResult" Disabled="@string.IsNullOrEmpty(outputText)" Class="ml-2">复制结果</MudButton>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string inputText = string.Empty;
    private string outputText = string.Empty;
    private string selectedAction = "summarize";
    private bool loading;
    private bool IsProcessDisabled => loading || string.IsNullOrWhiteSpace(inputText);

    private async Task Process()
    {
        var text = inputText.Trim();
        if (string.IsNullOrEmpty(text) || loading) return;

        loading = true;
        outputText = string.Empty;

        try
        {
            var systemPrompt = GetSystemPrompt(selectedAction);
            var reply = await Agent.ChatAsync(text, ModeState.CurrentMode, [], systemPrompt);
            outputText = reply;
        }
        catch (Exception ex)
        {
            outputText = $"处理失败: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void Clear()
    {
        inputText = string.Empty;
        outputText = string.Empty;
    }

    private async Task CopyResult()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", outputText);
    }

    private static string GetSystemPrompt(string action) => action switch
    {
        "summarize" => """
你是一位专业的文档摘要助手。请对用户提供的文本进行简明扼要的摘要，保留核心信息和关键点。
要求：
1. 提取主要内容和结论
2. 使用清晰的结构（分点或段落）
3. 长度控制在原文的1/3以内
4. 保持专业术语的准确性
""",
        "translate" => """
你是一位专业的翻译助手。请将用户提供的文本翻译成中文（如已是中文则翻译为英文）。
要求：
1. 准确传达原文含义
2. 保持专业术语的正确性
3. 语句通顺自然
4. 保留原文的格式和结构
""",
        "polish" => """
你是一位专业的文字润色助手。请对用户提供的文本进行润色优化。
要求：
1. 提高语言表达的专业性和流畅性
2. 修正语法和用词问题
3. 保持原文的核心意思不变
4. 使文本更具可读性和说服力
""",
        "expand" => """
你是一位专业的内容扩写助手。请对用户提供的文本进行扩写和丰富。
要求：
1. 在保持核心观点不变的前提下增加内容
2. 提供更多细节、例子和解释
3. 使内容更加充实和有深度
4. 扩展到原文的2-3倍长度
""",
        "rewrite" => """
你是一位专业的文字改写助手。请对用户提供的文本进行改写。
要求：
1. 保持原文的核心意思不变
2. 使用不同的表达方式和结构
3. 提高文本的可读性和吸引力
4. 避免与原文过于相似
""",
        "extract" => """
你是一位专业的要点提取助手。请从用户提供的文本中提取关键要点。
要求：
1. 列出3-5个核心要点
2. 每个要点简明扼要（不超过20字）
3. 按重要性排序
4. 使用清晰的编号或符号列表
""",
        _ => """
你是一位专业的文档处理助手。请根据用户的需求对文本进行处理。
要求：准确理解用户意图，提供高质量的处理结果。
"""
    };
}