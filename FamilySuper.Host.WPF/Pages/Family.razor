@page "/family"
@inject IRepository<FamilyMember> MemberRepo
@inject ICertificateService CertService
@inject IOcrService Ocr
@inject Services.ModeStateContainer ModeState
@inject ISnackbar Snackbar
@implements IDisposable

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>👨‍👩‍👧</span>
                        <span>家庭信息管理</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartAdd" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        添加成员
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudTable Items="members" Hover="true" Striped="true" Loading="loading">
                    <HeaderContent>
                        <MudTh>姓名</MudTh>
                        <MudTh>关系</MudTh>
                        <MudTh>性别</MudTh>
                        <MudTh>生日</MudTh>
                        <MudTh>电话</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Name</MudTd>
                        <MudTd>@context.Role</MudTd>
                        <MudTd>@(context.Gender?.ToString() == "Male" ? "男" : context.Gender?.ToString() == "Female" ? "女" : "未知")</MudTd>
                        <MudTd>@(context.BirthDate?.ToString("yyyy-MM-dd") ?? "-")</MudTd>
                        <MudTd>@(context.Phone ?? "-")</MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                <MudButton Color="Color.Info" OnClick="() => StartEdit(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="() => DeleteMember(context.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无家庭成员</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(editingMember?.Id > 0 ? "编辑成员" : "添加成员")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm Model="editingMember" @ref="_form" @bind-IsValid="_isFormValid">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="姓名 *" @bind-Value="editingMember!.Name" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="关系" @bind-Value="editingMember!.Role" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="性别" @bind-Value="editingMember!.Gender" T="Gender?">
                                    <MudSelectItem T="Gender?" Value="null">未选择</MudSelectItem>
                                    <MudSelectItem T="Gender?" Value="Gender.Male">男</MudSelectItem>
                                    <MudSelectItem T="Gender?" Value="Gender.Female">女</MudSelectItem>
                                    <MudSelectItem T="Gender?" Value="Gender.Unknown">未知</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="生日" @bind-Date="editingMember!.BirthDate" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="电话" @bind-Value="editingMember!.Phone" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="地址" @bind-Value="editingMember!.Address" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="父亲" @bind-Value="editingMember!.FatherId" T="long?">
                                    <MudSelectItem T="long?" Value="null">-- 无 --</MudSelectItem>
                                    @foreach (var m in members.Where(x => x.Id != editingMember?.Id && x.Gender == Gender.Male))
                                    {
                                        <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="母亲" @bind-Value="editingMember!.MotherId" T="long?">
                                    <MudSelectItem T="long?" Value="null">-- 无 --</MudSelectItem>
                                    @foreach (var m in members.Where(x => x.Id != editingMember?.Id && x.Gender == Gender.Female))
                                    {
                                        <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" OnClick="SaveMember" Disabled="@(!_isFormValid)" Variant="Variant.Filled">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelForm" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>

                    @if (editingMember?.Id == 0)
                    {
                        <div class="mt-4 pt-4 border-t">
                            <MudText Typo="Typo.body2" Class="mb-2">📄 身份证 OCR 识别</MudText>
                            <InputFile OnChange="OnOcrUpload" accept="image/*" />
                            @if (ocrLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Class="mt-2" />
                            }
                            @if (!string.IsNullOrEmpty(ocrMessage))
                            {
                                <MudAlert Severity="Severity.Success" Class="mt-2" Elevation="0">@ocrMessage</MudAlert>
                            }
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    <MudItem xs="12" Class="mt-4">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
                        <span>📁</span>
                        <span>证件管理</span>
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudSelect 
                    Label="选择成员" 
                    @bind-Value="selectedMemberIdForCert" 
                    T="long?" 
                    Placeholder="请选择成员"
                    Class="mb-4"
                    OnChange="LoadCertificates">
                    <MudSelectItem T="long?" Value="null">-- 请选择 --</MudSelectItem>
                    @foreach (var m in members)
                    {
                        <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                    }
                </MudSelect>
                
                @if (selectedMemberIdForCert.HasValue && certificates.Count > 0)
                {
                    <MudTable Items="certificates" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>名称</MudTh>
                            <MudTh>类型</MudTh>
                            <MudTh>号码</MudTh>
                            <MudTh>操作</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.Type</MudTd>
                            <MudTd>@(context.Number ?? "-")</MudTd>
                            <MudTd>
                                <MudButtonGroup Size="Size.Small">
                                    <MudButton Color="Color.Info" OnClick="() => DownloadCert(context.Id)">
                                        <MudIcon Icon="@Icons.Material.Filled.Download" />
                                    </MudButton>
                                    <MudButton Color="Color.Error" OnClick="() => DeleteCert(context.Id)">
                                        <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                    </MudButton>
                                </MudButtonGroup>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else if (selectedMemberIdForCert.HasValue)
                {
                    <MudAlert Severity="Severity.Info" Elevation="0">该成员暂无证件</MudAlert>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private MudForm _form = default!;
    private bool _isFormValid;
    private List<FamilyMember> members = new();
    private List<Certificate> certificates = new();
    private FamilyMember? editingMember;
    private bool showForm;
    private bool loading;
    private bool ocrLoading;
    private string? ocrMessage;
    private long? selectedMemberIdForCert;

    protected override async Task OnInitializedAsync()
    {
        await LoadMembers();
        ModeState.OnChange += StateChanged;
    }

    private async Task LoadMembers()
    {
        loading = true;
        members = await MemberRepo.GetAllAsync();
        loading = false;
    }

    private void StateChanged()
    {
        _ = LoadMembers();
        StateHasChanged();
    }

    private void StartAdd()
    {
        editingMember = new FamilyMember { CreatedAt = DateTime.UtcNow };
        showForm = true;
        ocrMessage = null;
    }

    private void StartEdit(FamilyMember m)
    {
        editingMember = m;
        showForm = true;
    }

    private async Task SaveMember()
    {
        await _form.ValidateAsync();
        if (!_isFormValid) return;
        try
        {
            if (editingMember!.Id > 0)
            {
                editingMember.UpdatedAt = DateTime.UtcNow;
                Snackbar.Add("家庭成员信息已更新", Severity.Success);
            }
            else
            {
                await MemberRepo.AddAsync(editingMember);
                Snackbar.Add("家庭成员已添加", Severity.Success);
            }
            await MemberRepo.SaveChangesAsync();
            showForm = false;
            editingMember = null;
            await LoadMembers();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
    }

    private void CancelForm()
    {
        showForm = false;
        editingMember = null;
    }

    private async Task DeleteMember(long id)
    {
        try
        {
            var m = await MemberRepo.GetByIdAsync(id);
            if (m is not null)
            {
                m.IsDeleted = true;
                m.UpdatedAt = DateTime.UtcNow;
                await MemberRepo.SaveChangesAsync();
                await LoadMembers();
                Snackbar.Add("家庭成员已删除", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnOcrUpload(InputFileChangeEventArgs e)
    {
        if (e.File is null || !Ocr.IsAvailable) return;
        ocrLoading = true;
        ocrMessage = null;
        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
            var result = await Ocr.RecognizeAsync(ms.ToArray());
            if (!string.IsNullOrEmpty(result.Name)) editingMember!.Name = result.Name;
            if (result.Gender == "男") editingMember!.Gender = Gender.Male;
            else if (result.Gender == "女") editingMember!.Gender = Gender.Female;
            if (DateTime.TryParseExact(result.BirthDate, "yyyyMMdd", null, System.Globalization.DateTimeStyles.None, out var birth))
                editingMember!.BirthDate = birth;
            ocrMessage = $"识别成功: {result.Name} / {result.Gender} / {result.BirthDate}";
        }
        catch (Exception ex)
        {
            ocrMessage = $"识别失败: {ex.Message}";
        }
        finally
        {
            ocrLoading = false;
        }
    }

    private async Task LoadCertificates(long? id)
    {
        selectedMemberIdForCert = id;
        if (id is null)
        {
            certificates = new();
            return;
        }
        certificates = await CertService.GetByMemberAsync(id);
    }

    private async Task DownloadCert(long id)
    {
        var fileData = await CertService.GetFileAsync(id);
        if (fileData is null) return;
        var (content, fileName) = fileData.Value;
        using var ms = new MemoryStream(content);
        await JS.InvokeVoidAsync("downloadFile", fileName, ms.ToArray());
    }

    private async Task DeleteCert(long id)
    {
        await CertService.DeleteAsync(id);
        if (selectedMemberIdForCert is not null)
            certificates = await CertService.GetByMemberAsync(selectedMemberIdForCert);
    }

    [Inject] IJSRuntime JS { get; set; } = default!;

    public void Dispose()
    {
        ModeState.OnChange -= StateChanged;
    }
}
