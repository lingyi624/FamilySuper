@page "/study-plan"
@inject IStudyService StudySvc
@inject IRepository<FamilyMember> MemberRepo

<MudGrid Class="max-w-5xl mx-auto">
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>📚</span>
                        <span>学习计划</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartAddPlan" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        新建计划
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Class="mb-4">
                    <MudItem xs="12" sm="4">
                        <MudSelect 
                            Label="成员" 
                            @bind-Value="filterMemberId" 
                            T="long?" 
                            Placeholder="全部">
                            <MudSelectItem T="long?" Value="null">全部</MudSelectItem>
                            @foreach (var m in members)
                            {
                                <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCheckBox @bind-Value="showInactive" Label="显示已停用" />
                    </MudItem>
                </MudGrid>
                <MudButton Color="Color.Secondary" OnClick="LoadPlans" Variant="Variant.Outlined" Size="Size.Small">刷新</MudButton>

                <MudTable Items="plans" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>科目</MudTh>
                        <MudTh>成员</MudTh>
                        <MudTh>目标</MudTh>
                        <MudTh>每周时长</MudTh>
                        <MudTh>进度</MudTh>
                        <MudTh>起止</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText Typo="Typo.body2" Class="font-bold">@context.Subject</MudText></MudTd>
                        <MudTd>@GetMemberName(context.MemberId)</MudTd>
                        <MudTd>@(context.Goal ?? "-")</MudTd>
                        <MudTd>@context.TargetHoursPerWeek 小时</MudTd>
                        <MudTd>
                            <div class="w-full bg-gray-200 rounded-full h-2 mb-1">
                                <div class="h-2 rounded-full transition-all" 
                                     style="width: @context.ProgressPercent%; background-color: @GetProgressColorHex(context.ProgressPercent)"></div>
                            </div>
                            <MudText Typo="Typo.caption">@context.ProgressPercent%</MudText>
                        </MudTd>
                        <MudTd>
                            @context.StartDate.ToString("yyyy-MM-dd")
                            @(context.EndDate == null ? " ~ 长期" : $" ~ {context.EndDate:yyyy-MM-dd}")
                        </MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                <MudButton Color="Color.Info" OnClick="() => StartLog(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.AddCircle" />
                                </MudButton>
                                <MudButton Color="Color.Info" OnClick="() => StartEditPlan(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="() => DeletePlan(context.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无学习计划</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showPlanForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(editingPlan.Id > 0 ? "编辑学习计划" : "新建学习计划")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm @ref="_form" @bind-IsValid="_isFormValid" Model="editingPlan">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="科目 *" @bind-Value="editingPlan.Subject" Required="true" Placeholder="如:数学、英语" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="成员" @bind-Value="editingPlan.MemberId" T="long?">
                                    <MudSelectItem T="long?" Value="null">请选择</MudSelectItem>
                                    @foreach (var m in members)
                                    {
                                        <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="学习目标" @bind-Value="editingPlan.Goal" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField Label="每周目标时长(小时)" @bind-Value="editingPlan.TargetHoursPerWeek" Min="1" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="开始日期" Date="editingPlan.StartDate" DateChanged="d => editingPlan.StartDate = d ?? DateTime.UtcNow" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="结束日期" @bind-Date="editingPlan.EndDate" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="备注" @bind-Value="editingPlan.Notes" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudCheckBox @bind-Value="editingPlan.IsActive" Label="启用此计划" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@(!_isFormValid)" OnClick="SavePlan">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelPlanForm" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    @if (showLogForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">记录学习 - @loggingPlan.Subject</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm Model="editingLog">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="学习日期" Date="editingLog.StudyDate" DateChanged="d => editingLog.StudyDate = d ?? DateTime.UtcNow" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField Label="时长(分钟)" @bind-Value="editingLog.DurationMinutes" Min="1" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="完成情况" @bind-Value="editingLog.Completion" T="string">
                                    <MudSelectItem T="string" Value="@("completed")">已完成</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("partial")">部分完成</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("skipped")">未完成</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="学习内容" @bind-Value="editingLog.Content" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="备注" @bind-Value="editingLog.Notes" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" OnClick="SaveLog" Variant="Variant.Filled">保存记录</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelLogForm" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    <MudItem xs="12" Class="mt-4">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
                        <span>📈</span>
                        <span>学习报告</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <div class="flex gap-2">
                        <MudDatePicker Label="从" @bind-Date="reportFrom" />
                        <MudDatePicker Label="到" @bind-Date="reportTo" />
                        <MudButton Color="Color.Primary" OnClick="LoadReport" Variant="Variant.Filled" Class="mt-2">生成</MudButton>
                    </div>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (report is not null)
                {
                    <MudGrid Class="mb-4">
                        <MudItem xs="12" sm="3">
                            <MudCard Elevation="0" Class="bg-gradient-to-br from-blue-500 to-blue-600 text-white">
                                <MudCardContent Class="text-center">
                                    <MudText Typo="Typo.h3" Class="font-bold">@report.TotalMinutes</MudText>
                                    <MudText Typo="Typo.caption" Class="opacity-80">总学习时长(分钟)</MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudCard Elevation="0" Class="bg-gradient-to-br from-green-500 to-green-600 text-white">
                                <MudCardContent Class="text-center">
                                    <MudText Typo="Typo.h3" Class="font-bold">@report.TotalSessions</MudText>
                                    <MudText Typo="Typo.caption" Class="opacity-80">学习次数</MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudCard Elevation="0" Class="bg-gradient-to-br from-orange-500 to-orange-600 text-white">
                                <MudCardContent Class="text-center">
                                    <MudText Typo="Typo.h3" Class="font-bold">@report.CompletionRate.ToString("F1")%</MudText>
                                    <MudText Typo="Typo.caption" Class="opacity-80">完成率</MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudCard Elevation="0" Class="bg-gradient-to-br from-purple-500 to-purple-600 text-white">
                                <MudCardContent Class="text-center">
                                    <MudText Typo="Typo.h3" Class="font-bold">@((report.TotalMinutes / 60.0).ToString("F1"))</MudText>
                                    <MudText Typo="Typo.caption" Class="opacity-80">总时长(小时)</MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>

                    @if (report.MinutesBySubject.Count > 0)
                    {
                        <MudText Typo="Typo.body2" Class="font-medium mb-2">按科目分布</MudText>
                        <div class="bar-chart">
                            @foreach (var kv in report.MinutesBySubject.OrderByDescending(x => x.Value))
                            {
                                var maxVal = report.MinutesBySubject.Values.Max();
                                var pctVal = maxVal > 0 ? (kv.Value * 100.0 / maxVal) : 0;
                                <div class="bar-row">
                                    <MudText Typo="Typo.body2" Class="w-20">@kv.Key</MudText>
                                    <div class="w-full bg-gray-200 rounded-full h-2 mx-2">
                                        <div class="h-2 rounded-full transition-all bg-primary" style="width: @pctVal%"></div>
                                    </div>
                                    <MudText Typo="Typo.body2" Class="w-16 text-right">@kv.Value 分</MudText>
                                </div>
                            }
                        </div>
                    }

                    @if (report.RecentLogs.Count > 0)
                    {
                        <MudText Typo="Typo.body2" Class="font-medium mb-2 mt-4">最近学习记录</MudText>
                        <MudTable Items="report.RecentLogs" Hover="true" Striped="true">
                            <HeaderContent>
                                <MudTh>日期</MudTh>
                                <MudTh>时长</MudTh>
                                <MudTh>完成情况</MudTh>
                                <MudTh>内容</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.StudyDate.ToString("yyyy-MM-dd HH:mm")</MudTd>
                                <MudTd>@context.DurationMinutes 分</MudTd>
                                <MudTd>
                                    <MudChip T="string" Color="@GetCompletionColor(context.Completion)" Size="Size.Small">@context.Completion</MudChip>
                                </MudTd>
                                <MudTd>@(context.Content ?? "-")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Elevation="0">该时段暂无学习记录</MudAlert>
                    }
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private List<FamilySuper.Core.Entities.StudyPlan> plans = new();
    private List<FamilyMember> members = new();
    private long? filterMemberId;
    private bool showInactive = false;
    private bool showPlanForm = false;
    private bool showLogForm = false;
    private FamilySuper.Core.Entities.StudyPlan editingPlan = new();
    private FamilySuper.Core.Entities.StudyPlan loggingPlan = new();
    private FamilySuper.Core.Entities.StudyLog editingLog = new();
    private MudForm _form = default!;
    private bool _isFormValid;
    private StudyReport? report;
    private DateTime? reportFrom = DateTime.UtcNow.AddDays(-30);
    private DateTime? reportTo = DateTime.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        members = await MemberRepo.GetAllAsync();
        await LoadPlans();
        await LoadReport();
    }

    private async Task LoadPlans()
    {
        plans = await StudySvc.GetPlansAsync(filterMemberId, !showInactive);
    }

    private string GetMemberName(long? id)
        => id == null ? "未指定" : members.FirstOrDefault(m => m.Id == id)?.Name ?? "未知";

    private string GetProgressColorHex(int percent)
        => percent >= 80 ? "#22c55e" : percent >= 50 ? "#f59e0b" : "#9ca3af";

    private Color GetCompletionColor(string completion)
        => completion switch { "completed" => Color.Success, "partial" => Color.Warning, _ => Color.Error };

    private void StartAddPlan()
    {
        editingPlan = new FamilySuper.Core.Entities.StudyPlan { StartDate = DateTime.UtcNow, IsActive = true, TargetHoursPerWeek = 5 };
        showPlanForm = true;
    }

    private void StartEditPlan(FamilySuper.Core.Entities.StudyPlan p)
    {
        editingPlan = new FamilySuper.Core.Entities.StudyPlan
        {
            Id = p.Id, MemberId = p.MemberId, Subject = p.Subject, Goal = p.Goal,
            TargetHoursPerWeek = p.TargetHoursPerWeek, ProgressPercent = p.ProgressPercent,
            StartDate = p.StartDate, EndDate = p.EndDate, IsActive = p.IsActive, Notes = p.Notes
        };
        showPlanForm = true;
    }

    private void CancelPlanForm() => showPlanForm = false;

    private async Task SavePlan()
    {
        await _form.ValidateAsync();
        if (!_isFormValid) return;
        if (editingPlan.Id > 0) await StudySvc.UpdatePlanAsync(editingPlan);
        else await StudySvc.AddPlanAsync(editingPlan);
        showPlanForm = false;
        await LoadPlans();
    }

    private async Task DeletePlan(long id)
    {
        await StudySvc.DeletePlanAsync(id);
        await LoadPlans();
    }

    private void StartLog(FamilySuper.Core.Entities.StudyPlan p)
    {
        loggingPlan = p;
        editingLog = new FamilySuper.Core.Entities.StudyLog
        {
            StudyPlanId = p.Id,
            MemberId = p.MemberId,
            StudyDate = DateTime.UtcNow,
            DurationMinutes = 30,
            Completion = "completed"
        };
        showLogForm = true;
    }

    private void CancelLogForm() => showLogForm = false;

    private async Task SaveLog()
    {
        await StudySvc.LogStudyAsync(editingLog);
        showLogForm = false;
        await LoadPlans();
        await LoadReport();
    }

    private async Task LoadReport()
    {
        var from = reportFrom ?? DateTime.UtcNow.AddDays(-30);
        var to = reportTo ?? DateTime.UtcNow;
        report = await StudySvc.GenerateReportAsync(filterMemberId, from, to);
    }
}

<style>
    .bar-chart { display: flex; flex-direction: column; gap: 8px; }
    .bar-row { display: flex; align-items: center; }
</style>