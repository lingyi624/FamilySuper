@page "/mode-switch"
@inject Services.ModeStateContainer ModeState
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using FamilySuper.Host.WPF.Components.Dialogs

<MudGrid Class="min-h-screen items-center justify-center p-4 bg-gray-50">
    <MudItem xs="12" sm="10" md="8" lg="6">
        <MudCard Elevation="8" Class="overflow-hidden" Style="padding:10px;">
            <div class="bg-gradient-to-br from-indigo-500 via-purple-600 to-pink-500 text-white p-8">
                <div class="flex flex-col items-center gap-4">
                    <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
@*                         <MudIcon Icon="@Icons.Material.Filled.ChatBubble" Size="Size.Medium" Color="Color.Primary" />
 *@                        <MudIcon Icon="@Icons.Material.Filled.SwitchAccount" Size="Size.Large" />

                        <span>模式切换</span>
 
                    </MudText>
                    @* <div class="icon-circle">
                        <MudIcon Icon="@Icons.Material.Filled.SwitchAccount" Size="Size.Large" /> 
                    </div> *@
                   <div class="text-center"> 
@*                          <MudText Typo="Typo.h4" Class="font-bold">模式切换</MudText>
 *@                        <MudText Typo="Typo.body2" Class="opacity-90 mt-2">切换模式需要管理员密码验证。两种模式拥有独立的数据视图。</MudText>
                    </div>  
                </div>
            </div>

            <MudCardContent Class="py-8 px-6">
                <div class="text-center mb-8">
                    <MudText Typo="Typo.body2" Class="text-gray-500 mb-3">当前模式</MudText> 
                    <MudChip T="string" Color="@(ModeState.CurrentMode == AppMode.Adult ? Color.Success : Color.Warning)" Size="Size.Medium" Variant="Variant.Filled">
                        <span class="text-lg">@(ModeState.CurrentMode == AppMode.Adult ? "👨 大人模式" : "🧒 小孩模式")</span>
                    </MudChip>
                </div>

                <MudGrid Spacing="4">
                    <MudItem xs="12" sm="6">
                        <div Style="padding:10px;"
                            @onclick="() => RequestSwitch(AppMode.Adult)"
                            class="@(ModeState.CurrentMode == AppMode.Adult ? "mode-card active" : "mode-card")">
                            <div class="py-6 text-center">
                                <div class="@(ModeState.CurrentMode == AppMode.Adult ? "mode-icon active" : "mode-icon") mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                                </div>
                                <MudText Typo="Typo.body1" FontWeight="FontWeight.Bold" Class="mb-2">大人模式</MudText>
                                <MudText Typo="Typo.caption" Class="text-gray-500 mb-4">完整功能 · 财务 · 工作 · 医疗</MudText>
                                @if (ModeState.CurrentMode == AppMode.Adult)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Class="mr-1" />
                                        当前模式
                                    </MudChip>
                                }
                            </div>
                        </div>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <div Style="padding:10px;"
                            @onclick="() => RequestSwitch(AppMode.Child)"
                            class="@(ModeState.CurrentMode == AppMode.Child ? "mode-card active" : "mode-card")">
                            <div class="py-6 text-center">
                                <div class="@(ModeState.CurrentMode == AppMode.Child ? "mode-icon active" : "mode-icon") mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.ChildCare" Size="Size.Large" />
                                </div>
                                <MudText Typo="Typo.body1" FontWeight="FontWeight.Bold" Class="mb-2">小孩模式</MudText>
                                <MudText Typo="Typo.caption" Class="text-gray-500 mb-4">内容过滤 · 教育优先 · 屏蔽财务</MudText>
                                @if (ModeState.CurrentMode == AppMode.Child)
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Class="mr-1" />
                                        当前模式
                                    </MudChip>
                                }
                            </div>
                        </div>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private async Task RequestSwitch(AppMode target)
    {
        if (ModeState.CurrentMode == target)
        {
            Snackbar.Add("已是该模式", Severity.Info);
            return;
        }

        var parameters = new DialogParameters
        {
            ["TargetMode"] = target,
            ["ModeName"] = target == AppMode.Adult ? "大人模式" : "小孩模式"
        };

        var dialog = await DialogService.ShowAsync<PasswordDialog>("验证管理员密码", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is string password)
        {
            var success = await ModeState.SwitchModeAsync(target, password);
            if (success)
            {
                Snackbar.Add($"已切换到 {(target == AppMode.Adult ? "大人" : "小孩")} 模式", Severity.Success);
            }
            else
            {
                Snackbar.Add("密码验证失败，请重试", Severity.Error);
            }
        }
    }
}

<style>
    .icon-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
    }

    .mode-card {
        cursor: pointer;
        transition: all 0.3s ease;
        border: 2px solid transparent;
        border-radius: 12px;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .mode-card:hover {
        transform: translateY(-4px);
        border-color: #e0e7ff;
        box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    }
    .mode-card.active {
        border-color: #6366f1;
        background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
        box-shadow: 0 4px 16px rgba(99, 102, 241, 0.2);
    }

    .mode-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #f0f4f8;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        color: #64748b;
        transition: all 0.3s ease;
    }
    .mode-icon.active {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        color: white;
        box-shadow: 0 4px 20px rgba(99, 102, 241, 0.3);
    }
</style>
