@page "/budget"
@inject IBudgetService BudgetSvc
@inject IRepository<FamilyMember> MemberRepo
@inject IDialogService DialogService
@using FamilySuper.Host.WPF.Components.Dialogs

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>📊</span>
                        <span>预算管理</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartAdd" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        设置预算
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Class="mb-4">
                    <MudItem xs="12" sm="3">
                        <MudNumericField Label="年份" @bind-Value="filterYear" Min="2000" Max="2100" OnValueChanged="LoadAll" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudNumericField Label="月份" @bind-Value="filterMonth" Min="1" Max="12" OnValueChanged="LoadAll" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudButton Color="Color.Default" OnClick="ResetMonth" Class="mt-6">本月</MudButton>
                    </MudItem>
                </MudGrid>

                @if (monthlyStatus.Count > 0)
                {
                    <MudText Typo="Typo.h6" Class="mb-4">📋 @filterYear 年 @filterMonth 月预算执行情况</MudText>
                    <MudTable Items="monthlyStatus" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>分类</MudTh>
                            <MudTh>预算金额</MudTh>
                            <MudTh>实际支出</MudTh>
                            <MudTh>剩余</MudTh>
                            <MudTh>使用率</MudTh>
                            <MudTh>状态</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><MudText FontWeight="FontWeight.Bold">@(string.IsNullOrEmpty(context.Budget.Category) ? "总预算" : context.Budget.Category)</MudText></MudTd>
                            <MudTd class="text-right">¥@context.Status.BudgetAmount.ToString("N2")</MudTd>
                            <MudTd class="text-right">¥@context.Status.ActualExpense.ToString("N2")</MudTd>
                            <MudTd class="text-right">
                                <MudText Class="@(context.Status.Remaining < 0 ? "text-red-600" : "text-green-600")" FontWeight="FontWeight.Bold">
                                    ¥@context.Status.Remaining.ToString("N2")
                                </MudText>
                            </MudTd>
                            <MudTd>
                                <div class="w-full bg-gray-200 rounded-full h-2 mb-1">
                                    <div class="h-2 rounded-full transition-all" 
                                         style="width: @((double)context.Status.UsagePercent)%; background-color: @GetProgressColorHex((double)context.Status.UsagePercent, context.Status.Remaining < 0)"></div>
                                </div>
                                <MudText Typo="Typo.caption">@context.Status.UsagePercent.ToString("F1")%</MudText>
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Color="@(context.Status.Remaining < 0 ? Color.Error : context.Status.UsagePercent >= 80 ? Color.Warning : Color.Success)" Size="Size.Small">
                                    @(context.Status.Remaining < 0 ? "超支" : context.Status.UsagePercent >= 80 ? "警戒" : "正常")
                                </MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Elevation="0">@filterYear 年 @filterMonth 月暂无预算设置</MudAlert>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" Class="mt-4">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
                        <span>📒</span>
                        <span>全部预算</span>
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTable Items="budgets" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>年月</MudTh>
                        <MudTh>分类</MudTh>
                        <MudTh>金额</MudTh>
                        <MudTh>成员</MudTh>
                        <MudTh>备注</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Year-@context.Month.ToString("00")</MudTd>
                        <MudTd><MudText FontWeight="FontWeight.Bold">@(string.IsNullOrEmpty(context.Category) ? "总预算" : context.Category)</MudText></MudTd>
                        <MudTd class="text-right font-bold">¥@context.Amount.ToString("N2")</MudTd>
                        <MudTd>@GetMemberName(context.MemberId)</MudTd>
                        <MudTd>@(context.Notes ?? "-")</MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                <MudButton Color="Color.Info" OnClick="() => StartEdit(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="() => Delete(context.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无预算</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(editing.Id > 0 ? "编辑预算" : "添加预算")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm @ref="_form" @bind-IsValid="_isFormValid" Model="editing">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudNumericField Label="年份 *" @bind-Value="editing.Year" Min="2000" Max="2100" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField Label="月份 *" @bind-Value="editing.Month" Min="1" Max="12" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="分类" @bind-Value="editing.Category" Placeholder="留空表示总预算;如:餐饮、教育" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField Label="金额 *" @bind-Value="editing.Amount" Min="0" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="成员" @bind-Value="editing.MemberId" T="long?">
                                    <MudSelectItem T="long?" Value="null">家庭</MudSelectItem>
                                    @foreach (var m in members)
                                    {
                                        <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="备注" @bind-Value="editing.Notes" Multiline="true" Rows="2" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@(!_isFormValid)" OnClick="Save">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelForm" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private List<FamilySuper.Core.Entities.Budget> budgets = new();
    private List<(FamilySuper.Core.Entities.Budget Budget, BudgetStatus Status)> monthlyStatus = new();
    private List<FamilyMember> members = new();
    private int filterYear = DateTime.UtcNow.Year;
    private int filterMonth = DateTime.UtcNow.Month;
    private bool showForm = false;
    private FamilySuper.Core.Entities.Budget editing = new();
    private MudForm _form = default!;
    private bool _isFormValid;

    protected override async Task OnInitializedAsync()
    {
        members = await MemberRepo.GetAllAsync();
        await LoadAll();
    }

    private async Task LoadAll()
    {
        budgets = await BudgetSvc.GetBudgetsAsync(null, null);
        monthlyStatus = await BudgetSvc.GetMonthlyStatusAsync(filterYear, filterMonth);
    }

    private string GetMemberName(long? memberId)
        => memberId == null ? "家庭" : members.FirstOrDefault(m => m.Id == memberId)?.Name ?? "未知";

    private static string GetProgressColorHex(double percent, bool isOverBudget)
        => isOverBudget ? "#ef4444" : percent >= 80 ? "#f59e0b" : "#22c55e";

    private void ResetMonth()
    {
        filterYear = DateTime.UtcNow.Year;
        filterMonth = DateTime.UtcNow.Month;
        _ = LoadAll();
    }

    private void StartAdd()
    {
        editing = new FamilySuper.Core.Entities.Budget
        {
            Year = filterYear,
            Month = filterMonth,
            Amount = 0
        };
        showForm = true;
    }

    private void StartEdit(FamilySuper.Core.Entities.Budget b)
    {
        editing = new FamilySuper.Core.Entities.Budget
        {
            Id = b.Id,
            Year = b.Year,
            Month = b.Month,
            Category = b.Category,
            Amount = b.Amount,
            MemberId = b.MemberId,
            Notes = b.Notes
        };
        showForm = true;
    }

    private void CancelForm() => showForm = false;

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_isFormValid) return;
        await BudgetSvc.AddOrUpdateAsync(editing);
        showForm = false;
        await LoadAll();
    }

    private async Task Delete(long id)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("确认删除");
        var result = await dialog.Result;
        if (result.Canceled) return;

        await BudgetSvc.DeleteAsync(id);
        await LoadAll();
    }
}
