@page "/"
@inject Services.ModeStateContainer ModeState
@inject IAgentService Agent

<MudGrid Class="max-w-6xl mx-auto">
    <MudItem xs="12">
        <MudCard Elevation="8" Class="bg-gradient-to-r from-indigo-500 to-purple-600 text-white">
            <MudCardContent>
                <div class="flex flex-wrap items-center justify-between gap-4">
                    <div>
                        <MudText Typo="Typo.h3" Class="mb-2">欢迎回家</MudText>
                        <MudText Typo="Typo.body1" Class="opacity-90">您的家庭智能中枢,守护每一位家人</MudText>
                    </div>
                    <MudChip T="string" Color="@(ModeState.CurrentMode == AppMode.Adult ? Color.Success : Color.Warning)" Size="Size.Medium" Class="px-3 py-1">
                        <span>@(ModeState.CurrentMode == AppMode.Adult ? "👨 大人模式" : "🧒 小孩模式")</span>
                    </MudChip>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3" Class="mt-4">
        <MudCard Hover="true" Elevation="2" Class="cursor-pointer transition-all duration-200 hover:elevation-8">
            <MudCardContent>
                <div class="flex items-start justify-between mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Large" Class="text-indigo-500" />
                    <MudChip T="string" Color="@(Agent.IsAvailable ? Color.Success : Color.Warning)" Size="Size.Small">
                        @(Agent.IsAvailable ? "已就绪" : "Mock")
                    </MudChip>
                </div>
                <MudText Typo="Typo.h6" Class="mb-1">智能对话</MudText>
                <MudText Typo="Typo.body2" Class="text-gray-500">基于 DeepSeek V4 Pro 的家庭管家,支持思考模式与工具调用</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3" Class="mt-4">
        <MudCard Hover="true" Elevation="2" Class="cursor-pointer transition-all duration-200 hover:elevation-8">
            <MudCardContent>
                <div class="flex items-start justify-between mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Class="text-green-500" />
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">已启用</MudChip>
                </div>
                <MudText Typo="Typo.h6" Class="mb-1">隐私保护</MudText>
                <MudText Typo="Typo.body2" Class="text-gray-500">所有数据本地存储,AES-256 加密,不上传云端</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3" Class="mt-4">
        <MudCard Hover="true" Elevation="2" Class="cursor-pointer transition-all duration-200 hover:elevation-8">
            <MudCardContent>
                <div class="flex items-start justify-between mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.SwitchAccount" Size="Size.Large" Class="text-blue-500" />
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">已配置</MudChip>
                </div>
                <MudText Typo="Typo.h6" Class="mb-1">模式切换</MudText>
                <MudText Typo="Typo.body2" Class="text-gray-500">大人/小孩模式独立数据视图,内容过滤</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3" Class="mt-4">
        <MudCard Hover="true" Elevation="2" Class="cursor-pointer transition-all duration-200 hover:elevation-8">
            <MudCardContent>
                <div class="flex items-start justify-between mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Cloud" Size="Size.Large" Class="text-orange-500" />
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">待启用</MudChip>
                </div>
                <MudText Typo="Typo.h6" Class="mb-1">多端协同</MudText>
                <MudText Typo="Typo.body2" Class="text-gray-500">桌面端 + H5 移动端,frp 内网穿透远程访问</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" Class="mt-6">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">快捷入口</MudText>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
                    <NavLink href="family" Class="quick-link">
                        <span class="text-2xl">👨‍👩‍👧</span>
                        <span>家庭</span>
                    </NavLink>
                    <NavLink href="chat" Class="quick-link">
                        <span class="text-2xl">💬</span>
                        <span>对话</span>
                    </NavLink>
                    <NavLink href="finance" Class="quick-link">
                        <span class="text-2xl">💰</span>
                        <span>财务</span>
                    </NavLink>
                    <NavLink href="health" Class="quick-link">
                        <span class="text-2xl">❤️</span>
                        <span>健康</span>
                    </NavLink>
                    <NavLink href="work" Class="quick-link">
                        <span class="text-2xl">💼</span>
                        <span>日程</span>
                    </NavLink>
                    <NavLink href="shopping" Class="quick-link">
                        <span class="text-2xl">🛒</span>
                        <span>购物</span>
                    </NavLink>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<style>
    .quick-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 16px 12px;
        border-radius: 8px;
        background: #f8fafc;
        text-decoration: none;
        color: #475569;
        transition: all 0.2s ease;
        gap: 4px;
    }
    .quick-link:hover {
        background: #e3f2fd;
        color: #1976d2;
        transform: translateY(-2px);
    }
</style>