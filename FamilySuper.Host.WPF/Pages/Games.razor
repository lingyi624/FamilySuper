@page "/games"

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>🎮</span>
                        <span>益智游戏</span>
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.Gamepad" Size="Size.Large" Class="text-gray-300 mb-4" />
                    <MudText Typo="Typo.h5" Class="mb-2">即将上线</MudText>
                    <MudText Typo="Typo.body2" Class="text-gray-500 mb-6">我们正在为您准备有趣的互动游戏,敬请期待!</MudText>
                    <MudGrid Class="w-full max-w-md">
                        <MudItem xs="6" Class="p-2">
                            <MudCard Elevation="1" Class="text-center">
                                <MudCardContent>
                                    <MudText Typo="Typo.h6">🧩</MudText>
                                    <MudText Typo="Typo.body2" Class="text-gray-600">益智拼图</MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="6" Class="p-2">
                            <MudCard Elevation="1" Class="text-center">
                                <MudCardContent>
                                    <MudText Typo="Typo.h6">📖</MudText>
                                    <MudText Typo="Typo.body2" Class="text-gray-600">成语接龙</MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="6" Class="p-2">
                            <MudCard Elevation="1" Class="text-center">
                                <MudCardContent>
                                    <MudText Typo="Typo.h6">🔢</MudText>
                                    <MudText Typo="Typo.body2" Class="text-gray-600">数学闯关</MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="6" Class="p-2">
                            <MudCard Elevation="1" Class="text-center">
                                <MudCardContent>
                                    <MudText Typo="Typo.h6">🌍</MudText>
                                    <MudText Typo="Typo.body2" Class="text-gray-600">地理探索</MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<style>
    .empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 40px; }
</style>
