@page "/survey"
@inject ISurveyService SurveySvc
@inject IRepository<FamilyMember> MemberRepo
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IDialogService DialogService
@using FamilySuper.Host.WPF.Components.Dialogs

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>📋</span>
                        <span>家庭调研</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartCreate" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        创建调研
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudCheckBox @bind-Value="showInactive" Label="显示已结束" OnChange="LoadSurveys" Class="mb-4" />

                <MudTable Items="surveys" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>标题</MudTh>
                        <MudTh>描述</MudTh>
                        <MudTh>状态</MudTh>
                        <MudTh>开始时间</MudTh>
                        <MudTh>响应数</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText FontWeight="FontWeight.Bold">@context.Title</MudText></MudTd>
                        <MudTd>@(context.Description ?? "-")</MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@GetStatusColor(context)" Size="Size.Small">
                                @GetStatusLabel(context)
                            </MudChip>
                        </MudTd>
                        <MudTd>@context.StartDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd>
                            <MudBadge Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Content="@(GetResponseCount(context.Id))">
                                @* @(GetResponseCount(context.Id)) *@
                            </MudBadge>
                        </MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                <MudButton Color="Color.Info" OnClick="@(() => ViewSurvey(context))">
                                    <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                                </MudButton>
                                @if (context.IsActive)
                                {
                                    <MudButton Color="Color.Primary" OnClick="@(() => FillSurvey(context))">填写</MudButton>
                                }
                                <MudButton Color="Color.Info" OnClick="@(() => StartEdit(context))">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="@(() => Delete(context.Id))">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无调研</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showCreateForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@GetFormTitle()</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm Model="editing" @ref="_form" @bind-IsValid="_isFormValid">
                        <MudGrid>
                            <MudItem xs="12">
                                <MudTextField Label="标题 *" @bind-Value="editing.Title" Required="true" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="描述" @bind-Value="editing.Description" Multiline="true" Rows="2" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField 
                                    Label="字段配置(JSON)" 
                                    @bind-Value="editing.FieldsJson" 
                                    Multiline="true" 
                                    Rows="6" 
                                    Placeholder='[{"name":"q1","label":"问题1","type":"text"},{"name":"q2","label":"问题2","type":"select","options":["选项A","选项B"]},{"name":"q3","label":"问题3","type":"multi","options":["A","B","C"]}]' />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="开始日期" @bind-Date="startDateValue" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="结束日期(可选)" @bind-Date="editing.EndDate" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudCheckBox @bind-Value="editing.IsActive" Label="启用此调研" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(!_isFormValid)" Variant="Variant.Filled">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelCreate" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    @if (showFillForm && currentSurvey is not null)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">填写调研 - @currentSurvey.Title</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (!string.IsNullOrEmpty(currentSurvey.Description))
                    {
                        <MudText Typo="Typo.body2" Class="text-gray-600 mb-4">@currentSurvey.Description</MudText>
                    }
                    <MudForm Model="currentSurvey" OnValidSubmit="Submit">
                        @foreach (var field in currentFields)
                        {
                            <MudItem xs="12" Class="mb-4">
                                <MudText Typo="Typo.body2" Class="font-medium mb-2">@field.Label *</MudText>
                                @if (field.Type == "select")
                                {
                                    <MudSelect Label="请选择" @bind-Value="fillValues[field.Name]" T="string">
                                        <MudSelectItem T="string" Value="null">请选择</MudSelectItem>
                                        @foreach (var opt in field.Options ?? [])
                                        {
                                            <MudSelectItem T="string" Value="@opt">@opt</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else if (field.Type == "multi")
                                {
                                    <div class="multi-select">
                                        @foreach (var opt in field.Options ?? [])
                                        {
                                            <MudCheckBox @bind-Value="multiValues[GetMultiKey(field.Name, opt)]" Label="@opt" />
                                        }
                                    </div>
                                }
                                else if (field.Type == "number")
                                {
                                    <MudNumericField Label="输入数字" @bind-Value="numValues[field.Name]" T="decimal" />
                                }
                                else if (field.Type == "date")
                                {
                                    <MudDatePicker Label="选择日期" @bind-Date="dateValues[field.Name]" />
                                }
                                else
                                {
                                    <MudTextField Label="输入内容" @bind-Value="fillValues[field.Name]" />
                                }
                            </MudItem>
                        }
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" Type="submit" Variant="Variant.Filled">提交</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelFill" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    @if (showStats && currentSurvey is not null && stats is not null)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">统计结果 - @currentSurvey.Title</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudPaper Class="mb-4 p-3">
                        <MudText Typo="Typo.body2">总响应数: <MudText Typo="Typo.h6" FontWeight="FontWeight.Bold">@stats.ResponseCount</MudText></MudText>
                    </MudPaper>
                    @foreach (var field in currentFields)
                    {
                        if (stats.Distribution.TryGetValue(field.Name, out var dist))
                        {
                            <MudText Typo="Typo.body2" FontWeight="FontWeight.Bold" Class="mb-2">@field.Label</MudText>
                            <div class="bar-chart">
                                @foreach (var kv in dist.OrderByDescending(x => x.Value))
                                {
                                    var max = dist.Values.Max();
                                    var pct = max > 0 ? (kv.Value * 100.0 / max) : 0;
                                    <div class="bar-row">
                                        <MudText Typo="Typo.body2" Class="bar-label">@kv.Key</MudText>
                                        <div class="progress-bar" style="width: @pct%;"></div>
                                        <MudText Typo="Typo.body2" Class="bar-value">@kv.Value</MudText>
                                    </div>
                                }
                            </div>
                        }
                    }
                    <MudButton Color="Color.Default" OnClick="CancelStats" Class="mt-4">返回列表</MudButton>
                    <MudButton Color="Color.Success" OnClick="ExportCsv" Class="mt-4 ml-2" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-1" />
                        导出CSV
                    </MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private MudForm _form = default!;
    private bool _isFormValid;
    private List<FamilySuper.Core.Entities.Survey> surveys = new();
    private Dictionary<long, int> responseCounts = new();
    private bool showInactive = false;
    private bool showCreateForm = false;
    private bool showFillForm = false;
    private bool showStats = false;
    private FamilySuper.Core.Entities.Survey editing = new();
    private FamilySuper.Core.Entities.Survey? currentSurvey;
    private List<SurveyField> currentFields = new();
    private SurveyStatistic? stats;
    private Dictionary<string, string> fillValues = new();
    private Dictionary<string, bool> multiValues = new();
    private Dictionary<string, decimal> numValues = new();
    private Dictionary<string, DateTime?> dateValues = new();
    private DateTime? startDateValue;

    protected override async Task OnInitializedAsync()
    {
        await LoadSurveys();
    }

    private async Task LoadSurveys()
    {
        surveys = await SurveySvc.GetSurveysAsync(showInactive ? null : true);
        responseCounts.Clear();
        foreach (var s in surveys)
        {
            var responses = await SurveySvc.GetResponsesAsync(s.Id);
            responseCounts[s.Id] = responses.Count;
        }
    }

    private void StartCreate()
    {
        editing = new FamilySuper.Core.Entities.Survey { StartDate = DateTime.UtcNow, IsActive = true };
        startDateValue = editing.StartDate;
        showCreateForm = true;
    }

    private void StartEdit(FamilySuper.Core.Entities.Survey s)
    {
        editing = new FamilySuper.Core.Entities.Survey
        {
            Id = s.Id, Title = s.Title, Description = s.Description,
            FieldsJson = s.FieldsJson, StartDate = s.StartDate,
            EndDate = s.EndDate, IsActive = s.IsActive
        };
        startDateValue = s.StartDate;
        showCreateForm = true;
    }

    private void CancelCreate() => showCreateForm = false;

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_isFormValid) return;
        try
        {
            if (startDateValue.HasValue) editing.StartDate = startDateValue.Value;
            if (editing.Id > 0)
            {
                await SurveySvc.UpdateSurveyAsync(editing);
                Snackbar.Add("调研已更新", Severity.Success);
            }
            else
            {
                await SurveySvc.AddSurveyAsync(editing);
                Snackbar.Add("调研已创建", Severity.Success);
            }
            showCreateForm = false;
            await LoadSurveys();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task Delete(long id)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("确认删除");
        var result = await dialog.Result;
        if (result.Canceled) return;

        try
        {
            await SurveySvc.DeleteSurveyAsync(id);
            await LoadSurveys();
            Snackbar.Add("调研已删除", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
        }
    }

    private void FillSurvey(FamilySuper.Core.Entities.Survey s)
    {
        currentSurvey = s;
        currentFields = ParseFields(s.FieldsJson);
        fillValues = new();
        multiValues = new();
        numValues = new();
        dateValues = new();
        foreach (var f in currentFields)
        {
            fillValues[f.Name] = string.Empty;
            numValues[f.Name] = 0;
            dateValues[f.Name] = null;
            if (f.Type == "multi")
            {
                foreach (var opt in f.Options ?? []) multiValues[GetMultiKey(f.Name, opt)] = false;
            }
        }
        showFillForm = true;
    }

    private void CancelFill() => showFillForm = false;

    private async Task Submit()
    {
        try
        {
            var json = BuildValuesJson();
            await SurveySvc.SubmitResponseAsync(new FamilySuper.Core.Entities.SurveyResponse
            {
                SurveyId = currentSurvey!.Id,
                ValuesJson = json
            });
            Snackbar.Add("响应已提交", Severity.Success);
            showFillForm = false;
            await LoadSurveys();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"提交失败: {ex.Message}", Severity.Error);
        }
    }

    private void ViewSurvey(FamilySuper.Core.Entities.Survey s)
    {
        currentSurvey = s;
        currentFields = ParseFields(s.FieldsJson);
        _ = LoadStats(s.Id);
    }

    private async Task LoadStats(long id)
    {
        stats = await SurveySvc.GetStatisticAsync(id);
        showStats = true;
    }

    private void CancelStats() => showStats = false;

    private int GetResponseCount(long id)
    {
        return responseCounts.TryGetValue(id, out var c) ? c : 0;
    }

    private string GetFormTitle()
    {
        return editing.Id > 0 ? "编辑调研" : "创建调研";
    }

    private static Color GetStatusColor(FamilySuper.Core.Entities.Survey s)
    {
        if (!s.IsActive) return Color.Default;
        if (s.EndDate.HasValue && s.EndDate < DateTime.UtcNow) return Color.Warning;
        return Color.Success;
    }

    private static string GetStatusLabel(FamilySuper.Core.Entities.Survey s)
    {
        if (!s.IsActive) return "已结束";
        if (s.EndDate.HasValue && s.EndDate < DateTime.UtcNow) return "已过期";
        return "进行中";
    }

    private static List<SurveyField> ParseFields(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return [];
        try { return System.Text.Json.JsonSerializer.Deserialize<List<SurveyField>>(json) ?? []; }
        catch { return []; }
    }

    private string BuildValuesJson()
    {
        var dict = new Dictionary<string, object>();
        foreach (var f in currentFields)
        {
            if (f.Type == "multi")
            {
                var selected = currentFields.First(x => x.Name == f.Name).Options?.Where(o => multiValues.TryGetValue(GetMultiKey(f.Name, o), out var v) && v).ToList();
                dict[f.Name] = selected ?? new List<string>();
            }
            else if (f.Type == "number")
            {
                if (numValues.TryGetValue(f.Name, out var n)) dict[f.Name] = n;
            }
            else if (f.Type == "date")
            {
                if (dateValues.TryGetValue(f.Name, out var d) && d.HasValue) dict[f.Name] = d.Value.ToString("yyyy-MM-dd");
            }
            else
            {
                dict[f.Name] = fillValues[f.Name];
            }
        }
        return System.Text.Json.JsonSerializer.Serialize(dict);
    }

    private async Task ExportCsv()
    {
        try
        {
            if (currentSurvey is null) return;
            var csv = await SurveySvc.ExportCsvAsync(currentSurvey.Id);
            var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("eval", $"const a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='survey_{currentSurvey.Id}.csv';a.click()");
            Snackbar.Add("数据导出成功", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"导出失败: {ex.Message}", Severity.Error);
        }
    }

    private static string GetMultiKey(string fieldName, string option)
    {
        return System.String.Concat(fieldName, "_", option);
    }
}

<style>
    .bar-chart { display: flex; flex-direction: column; gap: 8px; }
    .bar-row { display: flex; align-items: center; gap: 8px; }
    .bar-label { width: 100px; flex-shrink: 0; }
    .progress-bar { flex: 1; height: 8px; background-color: #6366f1; border-radius: 4px; }
    .bar-value { width: 40px; text-align: right; }
</style>