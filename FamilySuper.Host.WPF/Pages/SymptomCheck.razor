@page "/symptom"
@inject IAgentService Agent
@inject IRepository<FamilyMember> MemberRepo
@inject Services.ModeStateContainer ModeState

<div class="page-container">
    <div class="page-header">
        <h2>🩺 症状自诊</h2>
    </div>

    <div class="disclaimer-banner">
        ⚠️ <strong>重要提示:</strong> 本工具仅提供初步健康参考,不能替代专业医生诊断。危急情况请立即拨打120或前往医院。
    </div>

    <div class="section">
        <div class="form-row">
            <label>家庭成员</label>
            <select @bind="selectedMemberId">
                <option value="">未指定</option>
                @foreach (var m in members)
                {
                    <option value="@m.Id">@m.Name (@m.Role)</option>
                }
            </select>
        </div>
        <div class="form-row">
            <label>症状描述</label>
            <textarea @bind="symptomText" placeholder="请详细描述症状,例如:头痛3天,伴随低烧37.8度,乏力..." rows="4"></textarea>
        </div>
        <div class="form-actions">
            <button class="btn btn-primary" @onclick="Analyze" disabled="@loading || string.IsNullOrWhiteSpace(symptomText)">
                @(loading ? "分析中..." : "开始分析")
            </button>
            <button class="btn" @onclick="Clear" disabled="@loading">清空</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(result))
    {
        <div class="section result-section">
            <h3>📋 健康分析结果</h3>
            <div class="result-content">@result</div>
            <div class="followup-actions">
                <button class="btn btn-sm" @onclick="ContinueDialogue">继续追问</button>
            </div>
        </div>
    }

    @if (followupMode && !string.IsNullOrEmpty(result))
    {
        <div class="section">
            <h3>💬 继续对话</h3>
            <div class="followup-input">
                <textarea @bind="followupText" placeholder="补充症状或回答医生追问..." rows="3"></textarea>
                <button class="btn btn-primary" @onclick="SendFollowup" disabled="@loading || string.IsNullOrWhiteSpace(followupText)">
                    发送
                </button>
            </div>
        </div>
    }
</div>

@code {
    private List<FamilyMember> members = new();
    private long? selectedMemberId;
    private string symptomText = string.Empty;
    private string result = string.Empty;
    private bool loading;
    private bool followupMode;
    private string followupText = string.Empty;
    private readonly List<ChatMessage> dialogueHistory = new();

    protected override async Task OnInitializedAsync()
    {
        members = await MemberRepo.GetAllAsync();
    }

    private async Task Analyze()
    {
        var text = symptomText.Trim();
        if (string.IsNullOrEmpty(text) || loading) return;

        loading = true;
        result = string.Empty;
        dialogueHistory.Clear();
        var memberName = GetMemberName(selectedMemberId);
        var fullMessage = string.IsNullOrEmpty(memberName)
            ? text
            : $"【就诊成员:{memberName}】\n症状描述:{text}";

        try
        {
            dialogueHistory.Add(new ChatMessage("user", fullMessage));
            var reply = await Agent.ChatAsync(
                fullMessage,
                ModeState.CurrentMode,
                new List<ChatMessage>(),
                AgentPrompts.SymptomCheckSystemPrompt);
            result = reply;
            dialogueHistory.Add(new ChatMessage("assistant", reply));
            followupMode = true;
        }
        catch (Exception ex)
        {
            result = $"分析失败:{ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SendFollowup()
    {
        var text = followupText.Trim();
        if (string.IsNullOrEmpty(text) || loading) return;

        loading = true;
        followupText = string.Empty;
        try
        {
            dialogueHistory.Add(new ChatMessage("user", text));
            var history = dialogueHistory.Take(Math.Max(0, dialogueHistory.Count - 1)).ToList();
            var reply = await Agent.ChatAsync(
                text,
                ModeState.CurrentMode,
                history,
                AgentPrompts.SymptomCheckSystemPrompt);
            result += $"\n\n---\n\n【追问】{text}\n\n【回复】{reply}";
            dialogueHistory.Add(new ChatMessage("assistant", reply));
        }
        catch (Exception ex)
        {
            result += $"\n\n追问失败:{ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ContinueDialogue() => followupMode = true;

    private void Clear()
    {
        symptomText = string.Empty;
        result = string.Empty;
        followupText = string.Empty;
        followupMode = false;
        dialogueHistory.Clear();
    }

    private string GetMemberName(long? id)
        => id == null ? string.Empty : members.FirstOrDefault(m => m.Id == id)?.Name ?? string.Empty;
}

<style>
    .page-container { max-width: 900px; margin: 0 auto; padding: 20px; }
    .page-header { margin-bottom: 16px; }
    .page-header h2 { margin: 0; color: #333; font-size: 22px; }
    .disclaimer-banner { background: #fff3e0; border: 1px solid #ffb74d; border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; font-size: 13px; color: #e65100; line-height: 1.6; }
    .section { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 20px; }
    .section h3 { margin: 0 0 12px; font-size: 16px; color: #333; }
    .form-row { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px; }
    .form-row label { width: 80px; font-size: 14px; color: #555; padding-top: 8px; }
    .form-row select, .form-row textarea { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; font-family: inherit; }
    .form-row textarea { min-height: 80px; resize: vertical; }
    .form-actions { display: flex; gap: 8px; }
    .btn { padding: 8px 16px; border: 1px solid #ddd; border-radius: 6px; background: white; cursor: pointer; font-size: 14px; color: #555; }
    .btn:hover:not(:disabled) { background: #f0f4f8; }
    .btn-primary { background: #1976d2; color: white; border-color: #1976d2; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .result-section { border-left: 4px solid #1976d2; }
    .result-content { white-space: pre-wrap; line-height: 1.7; font-size: 14px; color: #333; }
    .followup-actions { margin-top: 16px; padding-top: 12px; border-top: 1px solid #eee; }
    .followup-input { display: flex; gap: 8px; align-items: flex-end; }
    .followup-input textarea { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; font-family: inherit; resize: vertical; }
</style>
