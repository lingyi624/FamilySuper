@page "/symptom"
@inject IAgentService Agent
@inject IRepository<FamilyMember> MemberRepo
@inject Services.ModeStateContainer ModeState

<MudGrid Class="max-w-4xl mx-auto">
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>🩺</span>
                        <span>症状自诊</span>
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudAlert Severity="Severity.Warning" Elevation="0" Class="mb-4">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Medium" />
                        <MudText>
                            <strong>重要提示:</strong> 本工具仅提供初步健康参考,不能替代专业医生诊断。危急情况请立即拨打120或前往医院。
                        </MudText>
                    </div>
                </MudAlert>

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect 
                            Label="家庭成员" 
                            @bind-Value="selectedMemberId" 
                            T="long?"
                            Placeholder="未指定">
                            <MudSelectItem T="long?" Value="null">未指定</MudSelectItem>
                            @foreach (var m in members)
                            {
                                <MudSelectItem T="long?" Value="m.Id">@m.Name (@m.Role)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                <div class="mt-4">
                    <MudTextField 
                        @bind-Value="symptomText" 
                        Label="症状描述"
                        Multiline="true"
                        Rows="4"
                        Placeholder="请详细描述症状,例如:头痛3天,伴随低烧37.8度,乏力..."
                        Class="w-full" />
                </div>

                <div class="form-actions mt-4">
                    <MudButton Color="Color.Primary" OnClick="Analyze" Disabled="@IsAnalyzeDisabled" Variant="Variant.Filled">
                        @(loading ? "分析中..." : "开始分析")
                    </MudButton>
                    <MudButton Color="Color.Default" OnClick="Clear" Disabled="@loading" Class="ml-2">清空</MudButton>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (!string.IsNullOrEmpty(result))
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4" Class="border-l-4 border-primary">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
                            <span>📋</span>
                            <span>健康分析结果</span>
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body1" Class="whitespace-pre-wrap" Style="line-height: 1.7;">@result</MudText>
                    <div class="mt-4 pt-4 border-t">
                        <MudButton Size="Size.Small" Color="Color.Info" OnClick="ContinueDialogue">
                            <MudIcon Icon="@Icons.Material.Filled.Message" Class="mr-1" />
                            继续追问
                        </MudButton>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    @if (followupMode && !string.IsNullOrEmpty(result))
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
                            <span>💬</span>
                            <span>继续对话</span>
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12">
                            <MudTextField 
                                @bind-Value="followupText" 
                                Label="补充症状或回答医生追问"
                                Multiline="true"
                                Rows="3"
                                Class="flex-1" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudButton Color="Color.Primary" OnClick="SendFollowup" Disabled="@IsSendDisabled" Variant="Variant.Filled" Class="mt-2">
                                <MudIcon Icon="@Icons.Material.Filled.Send" Class="mr-1" />
                                发送
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private List<FamilyMember> members = new();
    private long? selectedMemberId;
    private string symptomText = string.Empty;
    private string result = string.Empty;
    private bool loading;
    private bool followupMode;
    private bool IsAnalyzeDisabled => loading || string.IsNullOrWhiteSpace(symptomText);
    private bool IsSendDisabled => loading || string.IsNullOrWhiteSpace(followupText);
    private string followupText = string.Empty;
    private readonly List<ChatMessage> dialogueHistory = new();

    protected override async Task OnInitializedAsync()
    {
        members = await MemberRepo.GetAllAsync();
    }

    private async Task Analyze()
    {
        var text = symptomText.Trim();
        if (string.IsNullOrEmpty(text) || loading) return;

        loading = true;
        result = string.Empty;
        dialogueHistory.Clear();
        var memberName = GetMemberName(selectedMemberId);
        var fullMessage = string.IsNullOrEmpty(memberName)
            ? text
            : $"【就诊成员:{memberName}】\n症状描述:{text}";

        try
        {
            dialogueHistory.Add(new ChatMessage("user", fullMessage));
            var reply = await Agent.ChatAsync(
                fullMessage,
                ModeState.CurrentMode,
                new List<ChatMessage>(),
                AgentPrompts.SymptomCheckSystemPrompt);
            result = reply;
            dialogueHistory.Add(new ChatMessage("assistant", reply));
            followupMode = true;
        }
        catch (Exception ex)
        {
            result = $"分析失败:{ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SendFollowup()
    {
        var text = followupText.Trim();
        if (string.IsNullOrEmpty(text) || loading) return;

        loading = true;
        followupText = string.Empty;
        try
        {
            dialogueHistory.Add(new ChatMessage("user", text));
            var history = dialogueHistory.Take(Math.Max(0, dialogueHistory.Count - 1)).ToList();
            var reply = await Agent.ChatAsync(
                text,
                ModeState.CurrentMode,
                history,
                AgentPrompts.SymptomCheckSystemPrompt);
            result += $"\n\n---\n\n【追问】{text}\n\n【回复】{reply}";
            dialogueHistory.Add(new ChatMessage("assistant", reply));
        }
        catch (Exception ex)
        {
            result += $"\n\n追问失败:{ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ContinueDialogue() => followupMode = true;

    private void Clear()
    {
        symptomText = string.Empty;
        result = string.Empty;
        followupText = string.Empty;
        followupMode = false;
        dialogueHistory.Clear();
    }

    private string GetMemberName(long? id)
        => id == null ? string.Empty : members.FirstOrDefault(m => m.Id == id)?.Name ?? string.Empty;
}