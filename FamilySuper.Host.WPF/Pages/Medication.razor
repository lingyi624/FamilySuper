@page "/medication"
@inject IMedicationService MedSvc
@inject IRepository<FamilyMember> MemberRepo
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using FamilySuper.Host.WPF.Components.Dialogs
@implements IDisposable

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>💊</span>
                        <span>用药管理</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartAdd" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        添加用药计划
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (dueReminders.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4">
                        <div class="d-flex align-items-center gap-2">
                            <span><MudIcon Icon="@Icons.Material.Filled.Alarm" /></span>
                            <span>今日待服药 (@dueReminders.Count)</span>
                        </div>
                    </MudAlert>
                    <div class="reminder-list">
                        @foreach (var plan in dueReminders)
                        {
                            <MudCard Elevation="2" Class="mb-2">
                                <MudCardContent>
                                    <div class="d-flex justify-between align-items-center">
                                        <div>
                                            <MudText Typo="Typo.h6" FontWeight="FontWeight.Bold">@plan.DrugName</MudText>
                                            <MudText Typo="Typo.body2" Class="text-gray-500">
                                                @(plan.Dosage ?? "-") · @(plan.Frequency ?? "-") · @GetMemberName(plan.MemberId)
                                            </MudText>
                                        </div>
                                        <MudButton Color="Color.Success" OnClick="() => RecordDose(plan)" Variant="Variant.Filled">
                                            已服用
                                        </MudButton>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        }
                    </div>
                }

                <MudGrid Class="mt-4">
                    <MudItem xs="12" sm="4">
                        <MudSelect 
                            Label="成员" 
                            @bind-Value="filterMemberId" 
                            T="long?" 
                            Placeholder="全部"
                            OnChange="LoadPlans">
                            <MudSelectItem T="long?" Value="null">全部</MudSelectItem>
                            @foreach (var m in members)
                            {
                                <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCheckBox @bind-Value="showInactive" Label="显示已停用" OnChange="LoadPlans" />
                    </MudItem>
                </MudGrid>

                <MudTable Items="plans" Hover="true" Striped="true" Class="mt-4">
                    <HeaderContent>
                        <MudTh>药品</MudTh>
                        <MudTh>成员</MudTh>
                        <MudTh>剂量</MudTh>
                        <MudTh>频次</MudTh>
                        <MudTh>每日次数</MudTh>
                        <MudTh>起止</MudTh>
                        <MudTh>状态</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText FontWeight="FontWeight.Bold">@context.DrugName</MudText></MudTd>
                        <MudTd>@GetMemberName(context.MemberId)</MudTd>
                        <MudTd>@(context.Dosage ?? "-")</MudTd>
                        <MudTd>@(context.Frequency ?? "-")</MudTd>
                        <MudTd>@context.TimesPerDay</MudTd>
                        <MudTd>
                            @context.StartDate.ToString("yyyy-MM-dd")
                            @(context.EndDate == null ? " ~ 长期" : $" ~ {context.EndDate:yyyy-MM-dd}")
                        </MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                                @(context.IsActive ? "进行中" : "已停用")
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                <MudButton Color="Color.Info" OnClick="() => StartEdit(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="() => Delete(context.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无用药计划</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(editing.Id > 0 ? "编辑用药计划" : "添加用药计划")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm @ref="_form" @bind-IsValid="_isFormValid" Model="editing">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="药品名称 *" @bind-Value="editing.DrugName" Required="true" Placeholder="如:阿莫西林" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="家庭成员" @bind-Value="editing.MemberId" T="long?">
                                    <MudSelectItem T="long?" Value="null">请选择</MudSelectItem>
                                    @foreach (var m in members)
                                    {
                                        <MudSelectItem T="long?" Value="m.Id">@m.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="剂量" @bind-Value="editing.Dosage" Placeholder="如:1片" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="频次" @bind-Value="editing.Frequency" Placeholder="如:每日3次,饭后" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField Label="每日次数" @bind-Value="editing.TimesPerDay" Min="1" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="开始日期" @bind-Date="startDateValue" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="结束日期(留空为长期)" @bind-Date="editing.EndDate" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="备注" @bind-Value="editing.Notes" Multiline="true" Rows="2" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudCheckBox @bind-Value="editing.IsActive" Label="启用此计划" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(!_isFormValid)" Variant="Variant.Filled">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelForm" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private MudForm _form = default!;
    private bool _isFormValid;
    private List<MedicationPlan> plans = new();
    private List<MedicationPlan> dueReminders = new();
    private List<FamilyMember> members = new();
    private long? filterMemberId;
    private bool showInactive = false;
    private bool showForm = false;
    private MedicationPlan editing = new();
    private DateTime? startDateValue;

    protected override async Task OnInitializedAsync()
    {
        members = await MemberRepo.GetAllAsync();
        await LoadPlans();
        await LoadReminders();
    }

    private async Task LoadPlans()
    {
        plans = await MedSvc.GetPlansAsync(filterMemberId, !showInactive);
    }

    private async Task LoadReminders()
    {
        dueReminders = await MedSvc.GetDueRemindersAsync();
    }

    private string GetMemberName(long? memberId)
        => memberId == null ? "全体" : members.FirstOrDefault(m => m.Id == memberId)?.Name ?? "未知";

    private void StartAdd()
    {
        editing = new MedicationPlan { StartDate = DateTime.UtcNow, IsActive = true, TimesPerDay = 1 };
        startDateValue = editing.StartDate;
        showForm = true;
    }

    private void StartEdit(MedicationPlan p)
    {
        editing = new MedicationPlan
        {
            Id = p.Id, MemberId = p.MemberId, DrugName = p.DrugName,
            Dosage = p.Dosage, Frequency = p.Frequency, TimesPerDay = p.TimesPerDay,
            StartDate = p.StartDate, EndDate = p.EndDate, Notes = p.Notes, IsActive = p.IsActive
        };
        startDateValue = p.StartDate;
        showForm = true;
    }

    private void CancelForm() => showForm = false;

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_isFormValid) return;
        try
        {
            if (startDateValue.HasValue) editing.StartDate = startDateValue.Value;
            if (editing.Id > 0)
            {
                await MedSvc.UpdatePlanAsync(editing);
                Snackbar.Add("用药计划已更新", Severity.Success);
            }
            else
            {
                await MedSvc.AddPlanAsync(editing);
                Snackbar.Add("用药计划已添加", Severity.Success);
            }
            showForm = false;
            await LoadPlans();
            await LoadReminders();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task Delete(long id)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("确认删除");
        var result = await dialog.Result;
        if (result.Canceled) return;

        try
        {
            await MedSvc.DeletePlanAsync(id);
            await LoadPlans();
            await LoadReminders();
            Snackbar.Add("用药计划已删除", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task RecordDose(MedicationPlan plan)
    {
        try
        {
            await MedSvc.RecordDoseAsync(new MedicationRecord
            {
                MedicationPlanId = plan.Id,
                MemberId = plan.MemberId,
                TakenAt = DateTime.UtcNow,
                Status = "taken"
            });
            await LoadReminders();
            Snackbar.Add("已记录用药", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"记录失败: {ex.Message}", Severity.Error);
        }
    }

    public void Dispose() { }
}
