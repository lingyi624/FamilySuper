@page "/medication"
@inject IMedicationService MedSvc
@inject IRepository<FamilyMember> MemberRepo
@implements IDisposable

<div class="page-container">
    <div class="page-header">
        <h2>💊 用药管理</h2>
        <button class="btn btn-primary" @onclick="StartAdd">+ 添加用药计划</button>
    </div>

    @if (dueReminders.Count > 0)
    {
        <div class="section reminder-section">
            <h3>⏰ 今日待服药 (@dueReminders.Count)</h3>
            <div class="reminder-list">
                @foreach (var plan in dueReminders)
                {
                    <div class="reminder-card">
                        <div class="reminder-info">
                            <strong>@plan.DrugName</strong>
                            <span class="reminder-meta">
                                @(plan.Dosage ?? "-") · @(plan.Frequency ?? "-") ·
                                @(GetMemberName(plan.MemberId))
                            </span>
                        </div>
                        <button class="btn btn-sm btn-success" @onclick="() => RecordDose(plan)">已服用</button>
                    </div>
                }
            </div>
        </div>
    }

    <div class="section">
        <div class="filter-bar">
            <label>成员:</label>
            <select @bind="filterMemberId" @bind:after="LoadPlans">
                <option value="">全部</option>
                @foreach (var m in members)
                {
                    <option value="@m.Id">@m.Name</option>
                }
            </select>
            <label class="checkbox-label">
                <InputCheckbox @bind-Value="showInactive" />
                <span>显示已停用</span>
            </label>
        </div>
        <table class="data-table">
            <thead>
                <tr><th>药品</th><th>成员</th><th>剂量</th><th>频次</th><th>每日次数</th><th>起止</th><th>状态</th><th>操作</th></tr>
            </thead>
            <tbody>
                @foreach (var p in plans)
                {
                    <tr>
                        <td><strong>@p.DrugName</strong></td>
                        <td>@GetMemberName(p.MemberId)</td>
                        <td>@(p.Dosage ?? "-")</td>
                        <td>@(p.Frequency ?? "-")</td>
                        <td>@p.TimesPerDay</td>
                        <td>
                            @p.StartDate.ToString("yyyy-MM-dd")
                            @(p.EndDate == null ? " ~ 长期" : $" ~ {p.EndDate:yyyy-MM-dd}")
                        </td>
                        <td>
                            @if (p.IsActive)
                            { <span class="tag tag-green">进行中</span> }
                            else
                            { <span class="tag tag-gray">已停用</span> }
                        </td>
                        <td class="actions">
                            <button class="btn btn-sm" @onclick="() => StartEdit(p)">编辑</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(p.Id)">删除</button>
                        </td>
                    </tr>
                }
                @if (plans.Count == 0)
                {
                    <tr><td colspan="8" class="empty-row">暂无用药计划</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (showForm)
    {
        <div class="form-card">
            <h3>@(editing.Id > 0 ? "编辑用药计划" : "添加用药计划")</h3>
            <EditForm Model="editing" OnValidSubmit="Save">
                <div class="form-row">
                    <label>药品名称 *</label>
                    <InputText @bind-Value="editing.DrugName" placeholder="如:阿莫西林" />
                </div>
                <div class="form-row">
                    <label>家庭成员</label>
                    <InputSelect @bind-Value="editing.MemberId">
                        <option value="">请选择</option>
                        @foreach (var m in members)
                        {
                            <option value="@m.Id">@m.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="form-row">
                    <label>剂量</label>
                    <InputText @bind-Value="editing.Dosage" placeholder="如:1片" />
                </div>
                <div class="form-row">
                    <label>频次</label>
                    <InputText @bind-Value="editing.Frequency" placeholder="如:每日3次,饭后" />
                </div>
                <div class="form-row">
                    <label>每日次数</label>
                    <InputNumber @bind-Value="editing.TimesPerDay" />
                </div>
                <div class="form-row">
                    <label>开始日期</label>
                    <InputDate @bind-Value="editing.StartDate" />
                </div>
                <div class="form-row">
                    <label>结束日期(留空为长期)</label>
                    <InputDate @bind-Value="editing.EndDate" />
                </div>
                <div class="form-row">
                    <label>备注</label>
                    <InputTextArea @bind-Value="editing.Notes" />
                </div>
                <div class="form-row">
                    <label class="checkbox-label">
                        <InputCheckbox @bind-Value="editing.IsActive" />
                        <span>启用此计划</span>
                    </label>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">保存</button>
                    <button type="button" class="btn" @onclick="CancelForm">取消</button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private List<MedicationPlan> plans = new();
    private List<MedicationPlan> dueReminders = new();
    private List<FamilyMember> members = new();
    private long? filterMemberId;
    private bool showInactive = false;
    private bool showForm = false;
    private MedicationPlan editing = new();

    protected override async Task OnInitializedAsync()
    {
        members = await MemberRepo.GetAllAsync();
        await LoadPlans();
        await LoadReminders();
    }

    private async Task LoadPlans()
    {
        plans = await MedSvc.GetPlansAsync(filterMemberId, !showInactive);
    }

    private async Task LoadReminders()
    {
        dueReminders = await MedSvc.GetDueRemindersAsync();
    }

    private string GetMemberName(long? memberId)
        => memberId == null ? "全体" : members.FirstOrDefault(m => m.Id == memberId)?.Name ?? "未知";

    private void StartAdd()
    {
        editing = new MedicationPlan { StartDate = DateTime.UtcNow, IsActive = true, TimesPerDay = 1 };
        showForm = true;
    }

    private void StartEdit(MedicationPlan p)
    {
        editing = new MedicationPlan
        {
            Id = p.Id,
            MemberId = p.MemberId,
            DrugName = p.DrugName,
            Dosage = p.Dosage,
            Frequency = p.Frequency,
            TimesPerDay = p.TimesPerDay,
            StartDate = p.StartDate,
            EndDate = p.EndDate,
            Notes = p.Notes,
            IsActive = p.IsActive
        };
        showForm = true;
    }

    private void CancelForm() => showForm = false;

    private async Task Save()
    {
        if (editing.Id > 0)
        {
            await MedSvc.UpdatePlanAsync(editing);
        }
        else
        {
            await MedSvc.AddPlanAsync(editing);
        }
        showForm = false;
        await LoadPlans();
        await LoadReminders();
    }

    private async Task Delete(long id)
    {
        await MedSvc.DeletePlanAsync(id);
        await LoadPlans();
        await LoadReminders();
    }

    private async Task RecordDose(MedicationPlan plan)
    {
        await MedSvc.RecordDoseAsync(new MedicationRecord
        {
            MedicationPlanId = plan.Id,
            MemberId = plan.MemberId,
            TakenAt = DateTime.UtcNow,
            Status = "taken"
        });
        await LoadReminders();
    }

    public void Dispose() { }
}

<style>
    .page-container { max-width: 1000px; margin: 0 auto; padding: 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .page-header h2 { margin: 0; color: #333; font-size: 22px; }
    .section { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 20px; }
    .section h3 { margin: 0 0 12px; font-size: 16px; color: #333; }
    .filter-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
    .filter-bar label { font-size: 13px; color: #666; }
    .filter-bar select { padding: 6px 12px; border: 1px solid #ddd; border-radius: 6px; }
    .checkbox-label { display: flex; align-items: center; gap: 4px; cursor: pointer; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .data-table th { text-align: left; padding: 10px 12px; background: #f5f7fa; color: #666; font-weight: 600; border-bottom: 2px solid #e0e0e0; }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid #eee; }
    .data-table .empty-row { text-align: center; color: #999; padding: 24px; }
    .data-table .actions { display: flex; gap: 6px; }
    .tag { padding: 2px 8px; border-radius: 10px; font-size: 12px; font-weight: 600; background: #e3f2fd; color: #1565c0; }
    .tag-green { background: #e8f5e9; color: #2e7d32; }
    .tag-gray { background: #f5f5f5; color: #999; }
    .btn { padding: 6px 14px; border: 1px solid #ddd; border-radius: 6px; background: white; cursor: pointer; font-size: 13px; color: #555; }
    .btn:hover { background: #f0f4f8; }
    .btn-primary { background: #1976d2; color: white; border-color: #1976d2; }
    .btn-danger { color: #d32f2f; border-color: #ffcdd2; }
    .btn-success { background: #4caf50; color: white; border-color: #4caf50; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .form-card { background: white; border-radius: 12px; padding: 20px; margin-top: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 2px solid #e3f2fd; }
    .form-card h3 { margin: 0 0 16px; font-size: 17px; }
    .form-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .form-row label { width: 100px; font-size: 14px; color: #555; }
    .form-row input, .form-row select, .form-row textarea { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
    .form-row textarea { min-height: 60px; resize: vertical; }
    .form-actions { display: flex; gap: 8px; margin-top: 16px; }
    .reminder-section { border: 2px solid #fff3cd; background: #fffbeb; }
    .reminder-list { display: flex; flex-direction: column; gap: 8px; }
    .reminder-card { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: white; border-radius: 8px; border: 1px solid #ffe082; }
    .reminder-info { display: flex; flex-direction: column; gap: 2px; }
    .reminder-meta { font-size: 12px; color: #888; }
</style>

