@page "/education"
@inject IAgentService Agent
@inject IEducationService EducationSvc

<MudGrid Class="h-full">
    <MudItem xs="12" md="3">
        <MudCard Class="h-full">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
                        <span>📂</span>
                        <span>历史问答</span>
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudPaper Class="mb-4">
                    <MudChipGroup>
                        @foreach (var s in subjects)
                        {
                            <MudChip 
                                T="string" 
                                Color="@(selectedSubject == s ? Color.Primary : Color.Default)"
                                Variant="@(selectedSubject == s ? Variant.Filled : Variant.Outlined)"
                                OnClick="() => SelectSubject(s)">
                                @s
                            </MudChip>
                        }
                    </MudChipGroup>
                </MudPaper>

                <div class="history-list">
                    @foreach (var r in history)
                    {
                        <MudCard 
                            Elevation="@(selectedRecord?.Id == r.Id ? 2 : 0)"
                            Class="@GetHistoryCardClass(r.Id)"
                            OnClick="() => ViewRecord(r)">
                            <MudCardContent Class="py-2">
                                <MudText Typo="Typo.body2" Class="font-medium">@r.Question</MudText>
                                <MudText Typo="Typo.caption" Class="text-gray-500">
                                    @(r.RecordDate?.ToString("MM-dd HH:mm") ?? "-")
                                </MudText>
                            </MudCardContent>
                        </MudCard>
                    }
                    @if (history.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="text-center text-gray-400 py-8">暂无历史</MudText>
                    }
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudCard Class="h-full flex flex-col">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>📚</span>
                        <span>学习辅导</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudChip T="string" Color="@(Agent.IsAvailable ? Color.Success : Color.Warning)" Size="Size.Small">
                        @(Agent.IsAvailable ? "AI 已连接" : "Mock 模式")
                    </MudChip>
                </CardHeaderActions>
            </MudCardHeader>

            <div class="chat-window flex-1 overflow-y-auto p-4">
                @if (messages.Count == 0)
                {
                    <div class="empty-chat text-center py-12">
                        <MudIcon Icon="@Icons.Material.Filled.Book" Size="Size.Large" Class="text-gray-300 mb-4" />
                        <MudText Typo="Typo.h5" Class="mb-2">学习辅导助手</MudText>
                        <MudText Typo="Typo.body2" Class="text-gray-500 mb-6">选择学科,开始提问吧!</MudText>
                        <div class="tips">
                            <MudText Typo="Typo.body2" Class="text-gray-500">💡 启发式教学,引导思考</MudText>
                            <MudText Typo="Typo.body2" Class="text-gray-500">📖 涵盖语数英、理化生等学科</MudText>
                            <MudText Typo="Typo.body2" Class="text-gray-500">🛡️ 安全适宜,适合未成年人</MudText>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var msg in messages)
                    {
                        <div class="@(msg.Role == "user" ? "chat-message user" : "chat-message assistant")">
                            <div class="message-bubble">
                                @msg.Content
                            </div>
                        </div>
                    }
                    @if (loading)
                    {
                        <div class="chat-message assistant">
                            <div class="message-bubble">
                                <MudProgressCircular Size="Size.Small" Class="mr-2" />
                                <span>老师正在思考...</span>
                            </div>
                        </div>
                    }
                }
            </div>

            <MudCardContent>
                <div class="input-area">
                    <MudTextField 
                        @bind-Value="userInput" 
                        Placeholder="输入问题... (Enter 发送)"
                        Multiline="true" 
                        Rows="3"
                        Disabled="loading"
                        OnKeyDown="HandleKey"
                        Class="flex-1" />
                    <MudButton 
                        Color="Color.Primary" 
                        OnClick="Send" 
                        Disabled="@(loading || string.IsNullOrWhiteSpace(userInput))"
                        Variant="Variant.Filled"
                        Class="ml-2">
                        <MudIcon Icon="@Icons.Material.Filled.Send" />
                    </MudButton>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string userInput = string.Empty;
    private bool loading;
    private List<ChatMessage> messages = new();
    private List<EducationRecord> history = new();
    private EducationRecord? selectedRecord;
    private string selectedSubject = "语文";
    private readonly List<string> subjects = new() { "语文", "数学", "英语", "物理", "化学", "生物", "历史", "地理" };

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        history = await EducationSvc.GetRecordsAsync(subject: selectedSubject);
    }

    private async Task SelectSubject(string s)
    {
        selectedSubject = s;
        messages.Clear();
        selectedRecord = null;
        await LoadHistory();
    }

    private async Task Send()
    {
        var text = userInput.Trim();
        if (string.IsNullOrEmpty(text) || loading) return;

        messages.Add(new ChatMessage("user", text));
        var question = text;
        userInput = string.Empty;
        loading = true;

        try
        {
            var historyMsgs = messages.Take(Math.Max(0, messages.Count - 1)).ToList();
            var reply = await Agent.ChatAsync(question, AppMode.Child, historyMsgs, AgentPrompts.TutorSystemPrompt);
            messages.Add(new ChatMessage("assistant", reply));
            await EducationSvc.AddQaAsync(question, reply, selectedSubject);
            await LoadHistory();
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage("assistant", $"出错: {ex.Message}"));
        }
        finally
        {
            loading = false;
        }
    }

    private void ViewRecord(EducationRecord r)
    {
        selectedRecord = r;
        messages.Clear();
        messages.Add(new ChatMessage("user", r.Question));
        messages.Add(new ChatMessage("assistant", r.Answer));
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await Send();
    }

    private string GetHistoryCardClass(long id)
        => selectedRecord?.Id == id ? "bg-primary-light cursor-pointer" : "hover:bg-gray-50 cursor-pointer";
}

<style>
    .chat-message { display: flex; margin-bottom: 12px; }
    .chat-message.user { justify-content: flex-end; }
    .chat-message.assistant { justify-content: flex-start; }
    .message-bubble { max-width: 75%; padding: 12px 16px; border-radius: 16px; font-size: 14px; line-height: 1.6; white-space: pre-wrap; }
    .chat-message.user .message-bubble { background: #1976d2; color: white; border-bottom-right-radius: 4px; }
    .chat-message.assistant .message-bubble { background: #f0f4f8; color: #333; border-bottom-left-radius: 4px; }
    .input-area { display: flex; gap: 8px; }
    .history-list { display: flex; flex-direction: column; gap: 4px; }
    .tips { display: flex; flex-direction: column; gap: 4px; }
</style>
