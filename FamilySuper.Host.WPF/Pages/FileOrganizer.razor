@page "/file-organizer"
@inject IAgentService Agent
@inject Services.ModeStateContainer ModeState

<MudGrid Class="max-w-4xl mx-auto">
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>📁</span>
                        <span>文件分类整理</span>
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Class="text-gray-500 mb-4">上传文件并由AI自动分类和整理</MudText>

                <div class="upload-area">
                    <InputFile OnChange="FileSelected" multiple class="file-input" />
                    <div class="upload-content">
                        <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Large" Class="text-gray-400 mb-2" />
                        <MudText Typo="Typo.body1">点击选择文件上传</MudText>
                        <MudText Typo="Typo.caption" Class="text-gray-400">支持 PDF、Word、Excel、图片等格式</MudText>
                    </div>
                </div>

                @if (selectedFiles.Any())
                {
                    <div class="mt-4">
                        <MudText Typo="Typo.body2" Class="font-medium mb-2">已选择文件:</MudText>
                        <div class="files-list">
                            @foreach (var file in selectedFiles)
                            {
                                <MudCard Elevation="1" Class="mb-2">
                                    <MudCardContent Class="py-2">
                                        <div class="d-flex align-items-center gap-3">
                                            <span class="text-xl">@GetFileIcon(file.Name)</span>
                                            <div class="flex-1">
                                                <MudText Typo="Typo.body2" FontWeight="FontWeight.Medium">@file.Name</MudText>
                                                <MudText Typo="Typo.caption" Class="text-gray-500">@FormatSize(file.Size)</MudText>
                                            </div>
                                            <MudButton Size="Size.Small" Color="Color.Error" OnClick="() => RemoveFile(file)">
                                                <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                            </MudButton>
                                        </div>
                                    </MudCardContent>
                                </MudCard>
                            }
                        </div>
                    </div>

                    <div class="form-actions mt-4">
                        <MudButton Color="Color.Primary" OnClick="Organize" Disabled="@IsOrganizeDisabled" Variant="Variant.Filled">
                            @(loading ? "整理中..." : "开始整理")
                        </MudButton>
                        <MudButton Color="Color.Default" OnClick="Clear" Disabled="@loading" Class="ml-2">清空列表</MudButton>
                    </div>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showResults)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
                            <span>📋</span>
                            <span>分类结果</span>
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @foreach (var group in classificationGroups)
                    {
                        <MudCard Elevation="0" Class="mb-3 border">
                            <MudCardContent>
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <span class="text-xl">@group.Icon</span>
                                    <MudText Typo="Typo.body1" FontWeight="FontWeight.Bold">@group.Name</MudText>
                                    <MudBadge Color="Color.Primary" Size="Size.Small">@group.Files.Count</MudBadge>
                                </div>
                                <div class="flex flex-wrap gap-2 mb-2">
                                    @foreach (var f in group.Files)
                                    {
                                        <MudChip T="string" Color="Color.Info" Size="Size.Small">@f</MudChip>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(group.Summary))
                                {
                                    <MudText Typo="Typo.body2" Class="text-gray-600 mt-2">@group.Summary</MudText>
                                }
                            </MudCardContent>
                        </MudCard>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private List<IBrowserFile> selectedFiles = new();
    private List<ClassificationGroup> classificationGroups = new();
    private bool loading;
    private bool showResults;
    private bool IsOrganizeDisabled => loading || selectedFiles.Count == 0;

    private void FileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles()) selectedFiles.Add(file);
    }

    private void RemoveFile(IBrowserFile file) => selectedFiles.Remove(file);
    private void Clear() => selectedFiles.Clear();

    private async Task Organize()
    {
        if (!selectedFiles.Any()) return;
        loading = true;
        showResults = false;

        try
        {
            var fileNames = string.Join("\n", selectedFiles.Select(f => f.Name));
            var systemPrompt = """
你是一位专业的文件分类整理助手。请根据文件名判断文件类型并进行分类整理。

分类规则：
1. 文档类：PDF、Word、Excel、PPT、文本文件等
2. 图片类：JPG、PNG、GIF、BMP等图片格式
3. 视频类：MP4、AVI、MKV等视频格式
4. 音频类：MP3、WAV等音频格式
5. 压缩包：ZIP、RAR等压缩文件
6. 其他：无法分类的文件

请输出JSON格式结果：
{
    "groups": [
        {"name": "分类名称", "icon": "图标emoji", "files": ["文件名列表"], "summary": "简要描述"}
    ]
}
""";
            var reply = await Agent.ChatAsync($"文件列表：\n{fileNames}", ModeState.CurrentMode, [], systemPrompt);
            
            try
            {
                var result = System.Text.Json.JsonSerializer.Deserialize<ClassificationResult>(reply);
                classificationGroups = result?.Groups ?? [];
            }
            catch
            {
                classificationGroups = new List<ClassificationGroup>
                {
                    new ClassificationGroup { Name = "整理结果", Icon = "📋", Files = selectedFiles.Select(f => f.Name).ToList(), Summary = reply }
                };
            }
            showResults = true;
        }
        catch (Exception ex)
        {
            classificationGroups = new List<ClassificationGroup>
            {
                new ClassificationGroup { Name = "错误", Icon = "❌", Files = [], Summary = $"整理失败: {ex.Message}" }
            };
            showResults = true;
        }
        finally
        {
            loading = false;
        }
    }

    private static string GetFileIcon(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLower();
        return ext switch
        {
            ".pdf" => "📕", ".doc" or ".docx" => "📘", ".xls" or ".xlsx" => "📗",
            ".ppt" or ".pptx" => "📙", ".txt" => "📄", ".jpg" or ".jpeg" or ".png" or ".gif" => "🖼️",
            ".mp4" or ".avi" or ".mkv" => "🎬", ".mp3" or ".wav" => "🎵",
            ".zip" or ".rar" or ".7z" => "📦", _ => "📄"
        };
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private class ClassificationResult { public List<ClassificationGroup> Groups { get; set; } = []; }
    private class ClassificationGroup
    {
        public string Name { get; set; } = string.Empty;
        public string Icon { get; set; } = "📁";
        public List<string> Files { get; set; } = [];
        public string? Summary { get; set; }
    }
}

<style>
    .upload-area { border: 2px dashed #ddd; border-radius: 12px; padding: 40px; text-align: center; cursor: pointer; transition: border-color 0.2s; }
    .upload-area:hover { border-color: #1976d2; }
    .file-input { display: none; }
    .upload-content { display: flex; flex-direction: column; align-items: center; }
    .files-list { max-height: 300px; overflow-y: auto; }
</style>