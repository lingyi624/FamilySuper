@page "/medical-guide"

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>🏥</span>
                        <span>就医指南</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartAdd" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        添加指南
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Class="mb-4">
                    <MudItem xs="12" sm="6">
                        <MudSelect Label="分类" @bind-Value="filterCategory" T="string?" Placeholder="全部" OnChange="LoadGuides">
                            <MudSelectItem T="string?" Value="null">全部</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("综合医院")">综合医院</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("专科医院")">专科医院</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("社区诊所")">社区诊所</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("药房")">药房</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                <MudTable Items="guides" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>标题</MudTh>
                        <MudTh>医院</MudTh>
                        <MudTh>科室</MudTh>
                        <MudTh>医生</MudTh>
                        <MudTh>评分</MudTh>
                        <MudTh>分类</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText FontWeight="FontWeight.Bold">@context.Title</MudText></MudTd>
                        <MudTd>@context.HospitalName</MudTd>
                        <MudTd>@(context.Department ?? "-")</MudTd>
                        <MudTd>@(context.DoctorName ?? "-")</MudTd>
                        <MudTd>
                            @for (int i = 0; i < context.Rating; i++)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                            }
                        </MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@GetCategoryColor(context.Category)" Size="Size.Small">@context.Category</MudChip>
                        </MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                <MudButton Color="Color.Info" OnClick="() => StartEdit(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="() => Delete(context.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无就医指南</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(editing.Id > 0 ? "编辑就医指南" : "添加就医指南")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm Model="editing" @ref="_form" @bind-IsValid="_isFormValid">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="标题 *" @bind-Value="editing.Title" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="医院名称 *" @bind-Value="editing.HospitalName" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="科室" @bind-Value="editing.Department" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="医生姓名" @bind-Value="editing.DoctorName" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="地址" @bind-Value="editing.Address" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="电话" @bind-Value="editing.Phone" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="分类" @bind-Value="editing.Category" T="string">
                                    <MudSelectItem T="string" Value="@("综合医院")">综合医院</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("专科医院")">专科医院</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("社区诊所")">社区诊所</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("药房")">药房</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="评分" @bind-Value="editing.Rating" T="int">
                                    <MudSelectItem T="int" Value="1">1星</MudSelectItem>
                                    <MudSelectItem T="int" Value="2">2星</MudSelectItem>
                                    <MudSelectItem T="int" Value="3">3星</MudSelectItem>
                                    <MudSelectItem T="int" Value="4">4星</MudSelectItem>
                                    <MudSelectItem T="int" Value="5">5星</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="挂号方式" @bind-Value="editing.RegistrationMethod" Placeholder="线上/现场/电话" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="就诊流程" @bind-Value="editing.Description" Multiline="true" Rows="3" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="备注" @bind-Value="editing.Notes" Multiline="true" Rows="2" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(!_isFormValid)" Variant="Variant.Filled">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelForm" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

