@page "/finance"
@inject IFinanceService FinanceSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using FamilySuper.Host.WPF.Components.Dialogs

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>💰</span>
                        <span>财务管理</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartAdd" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        添加记录
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Class="mb-4">
                    <MudItem xs="12" sm="4">
                        <MudCard>
                            <MudCardContent Class="text-center">
                                <MudText Typo="Typo.body2" Class="text-gray-500">收入</MudText>
                                <MudText Typo="Typo.h4" Class="text-green-600 font-bold">¥@summary.TotalIncome.ToString("N2")</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCard>
                            <MudCardContent Class="text-center">
                                <MudText Typo="Typo.body2" Class="text-gray-500">支出</MudText>
                                <MudText Typo="Typo.h4" Class="text-red-600 font-bold">¥@summary.TotalExpense.ToString("N2")</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCard>
                            <MudCardContent Class="text-center">
                                <MudText Typo="Typo.body2" Class="text-gray-500">余额</MudText>
                                <MudText Typo="Typo.h4" Class="text-blue-600 font-bold">¥@summary.Balance.ToString("N2")</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>

                <MudSelect 
                    Label="筛选类型" 
                    @bind-Value="filterType" 
                    T="FinanceType?"
                    Placeholder="全部类型"
                    Class="mb-4"
                    OnChange="LoadRecords">
                    <MudSelectItem T="FinanceType?" Value="null">全部类型</MudSelectItem>
                    <MudSelectItem T="FinanceType?" Value="FinanceType.Income">收入</MudSelectItem>
                    <MudSelectItem T="FinanceType?" Value="FinanceType.Expense">支出</MudSelectItem>
                </MudSelect>

                <MudTable Items="records" T="FinanceRecord" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>标题</MudTh>
                        <MudTh>类型</MudTh>
                        <MudTh>金额</MudTh>
                        <MudTh>类别</MudTh>
                        <MudTh>日期</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Title</MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@(context.Type == FinanceType.Income ? Color.Success : Color.Error)" Size="Size.Small">
                                @(context.Type == FinanceType.Income ? "收入" : "支出")
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            <MudText Class="@(context.Type == FinanceType.Income ? "text-green-600" : "text-red-600")" FontWeight="FontWeight.Bold">
                                ¥@context.Amount.ToString("N2")
                            </MudText>
                        </MudTd>
                        <MudTd>@(context.Category ?? "-")</MudTd>
                        <MudTd>@(context.RecordDate?.ToString("yyyy-MM-dd") ?? "-")</MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                <MudButton Color="Color.Info" OnClick="() => StartEdit(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="() => Delete(context.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无记录</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(editing.Id > 0 ? "编辑记录" : "添加记录")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm @ref="_form" @bind-IsValid="_isFormValid" Model="editing">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="标题 *" @bind-Value="editing.Title" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="类型 *" @bind-Value="editing.Type" T="FinanceType" Required="true">
                                    <MudSelectItem T="FinanceType" Value="FinanceType.Income">收入</MudSelectItem>
                                    <MudSelectItem T="FinanceType" Value="FinanceType.Expense">支出</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField Label="金额 *" @bind-Value="editing.Amount" Min="0" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="类别" @bind-Value="editing.Category" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="日期" @bind-Date="editing.RecordDate" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="备注" @bind-Value="editing.Remark" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(!_isFormValid)" Variant="Variant.Filled">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="Cancel" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private MudForm _form = default!;
    private bool _isFormValid;
    private List<FinanceRecord> records = new();
    private FinanceSummary summary = new(0, 0, 0, 0);
    private FinanceRecord editing = new();
    private bool showForm;
    private FinanceType? filterType;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecords();
    }

    private async Task LoadRecords()
    {
        records = await FinanceSvc.GetRecordsAsync(filterType);
        summary = await FinanceSvc.GetSummaryAsync();
    }

    private void StartAdd()
    {
        editing = new FinanceRecord { RecordDate = DateTime.UtcNow, CreatedAt = DateTime.UtcNow };
        showForm = true;
    }

    private void StartEdit(FinanceRecord r)
    {
        editing = new FinanceRecord
        {
            Id = r.Id, Title = r.Title, Type = r.Type, Amount = r.Amount,
            Category = r.Category, RecordDate = r.RecordDate, Remark = r.Remark,
            CreatedAt = r.CreatedAt
        };
        showForm = true;
    }

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_isFormValid) return;
        try
        {
            if (editing.Id > 0)
            {
                await FinanceSvc.UpdateAsync(editing);
                Snackbar.Add("收支记录已更新", Severity.Success);
            }
            else
            {
                await FinanceSvc.AddAsync(editing);
                Snackbar.Add("收支记录已添加", Severity.Success);
            }
            showForm = false;
            await LoadRecords();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => showForm = false;

    private async Task Delete(long id)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("确认删除");
        var result = await dialog.Result;
        if (result.Canceled) return;

        try
        {
            await FinanceSvc.DeleteAsync(id);
            await LoadRecords();
            Snackbar.Add("收支记录已删除", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
        }
    }
}
