@page "/finance"
@inject IFinanceService FinanceSvc

<div class="page-container">
    <div class="page-header">
        <h2>💰 财务管理</h2>
        <button class="btn btn-primary" @onclick="StartAdd">+ 添加记录</button>
    </div>

    <div class="summary-cards">
        <div class="summary-card income">
            <div class="label">收入</div>
            <div class="amount">¥@summary.TotalIncome.ToString("N2")</div>
        </div>
        <div class="summary-card expense">
            <div class="label">支出</div>
            <div class="amount">¥@summary.TotalExpense.ToString("N2")</div>
        </div>
        <div class="summary-card balance">
            <div class="label">余额</div>
            <div class="amount">¥@summary.Balance.ToString("N2")</div>
        </div>
    </div>

    <div class="section">
        <div class="filter-bar">
            <select @bind="filterType" @bind:after="LoadRecords">
                <option value="">全部类型</option>
                <option value="Income">收入</option>
                <option value="Expense">支出</option>
            </select>
        </div>
        <table class="data-table">
            <thead>
                <tr><th>标题</th><th>类型</th><th>金额</th><th>类别</th><th>日期</th><th>操作</th></tr>
            </thead>
            <tbody>
                @foreach (var r in records)
                {
                    <tr>
                        <td>@r.Title</td>
                        <td><span class="tag @(r.Type == FinanceType.Income ? "tag-green" : "tag-red")">@r.Type</span></td>
                        <td class="@(r.Type == FinanceType.Income ? "text-green" : "text-red")">¥@r.Amount.ToString("N2")</td>
                        <td>@(r.Category ?? "-")</td>
                        <td>@r.RecordDate.ToString("yyyy-MM-dd")</td>
                        <td class="actions">
                            <button class="btn btn-sm" @onclick="() => StartEdit(r)">编辑</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(r.Id)">删除</button>
                        </td>
                    </tr>
                }
                @if (records.Count == 0)
                {
                    <tr><td colspan="6" class="empty-row">暂无记录</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (showForm)
    {
        <div class="form-card">
            <h3>@(editing.Id > 0 ? "编辑记录" : "添加记录")</h3>
            <EditForm Model="editing" OnValidSubmit="Save">
                <div class="form-row"><label>标题 *</label><InputText @bind-Value="editing.Title" /></div>
                <div class="form-row">
                    <label>类型 *</label>
                    <InputSelect @bind-Value="editing.Type">
                        <option value="Income">收入</option>
                        <option value="Expense">支出</option>
                    </InputSelect>
                </div>
                <div class="form-row"><label>金额 *</label><InputNumber @bind-Value="editing.Amount" /></div>
                <div class="form-row"><label>类别</label><InputText @bind-Value="editing.Category" /></div>
                <div class="form-row"><label>日期</label><InputDate @bind-Value="editing.RecordDate" /></div>
                <div class="form-row"><label>备注</label><InputText @bind-Value="editing.Remark" /></div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">保存</button>
                    <button type="button" class="btn" @onclick="Cancel">取消</button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private List<FinanceRecord> records = new();
    private FinanceSummary summary = new(0, 0, 0, 0);
    private FinanceRecord editing = new();
    private bool showForm;
    private FinanceType? filterType;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecords();
    }

    private async Task LoadRecords()
    {
        records = await FinanceSvc.GetRecordsAsync(filterType);
        summary = await FinanceSvc.GetSummaryAsync();
    }

    private void StartAdd()
    {
        editing = new FinanceRecord { RecordDate = DateTime.UtcNow, CreatedAt = DateTime.UtcNow };
        showForm = true;
    }

    private void StartEdit(FinanceRecord r)
    {
        editing = new FinanceRecord
        {
            Id = r.Id, Title = r.Title, Type = r.Type, Amount = r.Amount,
            Category = r.Category, RecordDate = r.RecordDate, Remark = r.Remark,
            CreatedAt = r.CreatedAt
        };
        showForm = true;
    }

    private async Task Save()
    {
        if (editing.Id > 0)
            await FinanceSvc.UpdateAsync(editing);
        else
            await FinanceSvc.AddAsync(editing);
        showForm = false;
        await LoadRecords();
    }

    private void Cancel() => showForm = false;

    private async Task Delete(long id)
    {
        await FinanceSvc.DeleteAsync(id);
        await LoadRecords();
    }
}

<style>
    .page-container { max-width: 1000px; margin: 0 auto; padding: 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .page-header h2 { margin: 0; color: #333; font-size: 22px; }
    .summary-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 20px; }
    .summary-card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .summary-card .label { font-size: 13px; color: #888; margin-bottom: 8px; }
    .summary-card .amount { font-size: 24px; font-weight: 700; }
    .summary-card.income .amount { color: #2e7d32; }
    .summary-card.expense .amount { color: #d32f2f; }
    .summary-card.balance .amount { color: #1976d2; }
    .section { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .filter-bar { margin-bottom: 12px; }
    .filter-bar select { padding: 6px 12px; border: 1px solid #ddd; border-radius: 6px; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .data-table th { text-align: left; padding: 10px 12px; background: #f5f7fa; color: #666; font-weight: 600; border-bottom: 2px solid #e0e0e0; }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid #eee; }
    .data-table .empty-row { text-align: center; color: #999; padding: 24px; }
    .data-table .actions { display: flex; gap: 6px; }
    .tag { padding: 2px 8px; border-radius: 10px; font-size: 12px; font-weight: 600; }
    .tag-green { background: #e8f5e9; color: #2e7d32; }
    .tag-red { background: #ffebee; color: #d32f2f; }
    .text-green { color: #2e7d32; font-weight: 600; }
    .text-red { color: #d32f2f; font-weight: 600; }
    .btn { padding: 6px 14px; border: 1px solid #ddd; border-radius: 6px; background: white; cursor: pointer; font-size: 13px; color: #555; }
    .btn:hover { background: #f0f4f8; }
    .btn-primary { background: #1976d2; color: white; border-color: #1976d2; }
    .btn-danger { color: #d32f2f; border-color: #ffcdd2; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .form-card { background: white; border-radius: 12px; padding: 20px; margin-top: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 2px solid #e3f2fd; }
    .form-card h3 { margin: 0 0 16px; font-size: 17px; }
    .form-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .form-row label { width: 80px; font-size: 14px; color: #555; }
    .form-row input, .form-row select { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
    .form-actions { display: flex; gap: 8px; margin-top: 16px; }
</style>
