@page "/meeting-assistant"
@inject IMeetingNoteService MeetingSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using FamilySuper.Host.WPF.Components.Dialogs

<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="d-flex align-center gap-2">
                        <span>📋</span>
                        <span>会议助手</span>
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Color="Color.Primary" OnClick="StartAdd" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
                        新建会议
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Class="mb-4">
                    <MudItem xs="12" sm="4">
                        <MudSelect Label="状态" @bind-Value="filterStatus" T="string?" Placeholder="全部" OnChange="LoadNotes">
                            <MudSelectItem T="string?" Value="null">全部</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("已安排")">已安排</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("进行中")">进行中</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("已结束")">已结束</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("已取消")">已取消</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                <MudTable Items="notes" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>标题</MudTh>
                        <MudTh>日期</MudTh>
                        <MudTh>时长</MudTh>
                        <MudTh>参会人员</MudTh>
                        <MudTh>地点</MudTh>
                        <MudTh>状态</MudTh>
                        <MudTh>操作</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText FontWeight="FontWeight.Bold">@context.Title</MudText></MudTd>
                        <MudTd>@context.MeetingDate.ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd>@context.DurationMinutes 分钟</MudTd>
                        <MudTd>@(context.Attendees ?? "-")</MudTd>
                        <MudTd>@(context.Location ?? "-")</MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                        </MudTd>
                        <MudTd>
                            <MudButtonGroup Size="Size.Small">
                                <MudButton Color="Color.Info" OnClick="() => StartEdit(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                </MudButton>
                                <MudButton Color="Color.Error" OnClick="() => Delete(context.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                </MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudAlert Severity="Severity.Info" Elevation="0">暂无会议记录</MudAlert>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (showForm)
    {
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(editing.Id > 0 ? "编辑会议" : "新建会议")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm Model="editing" @ref="_form" @bind-IsValid="_isFormValid">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="会议标题 *" @bind-Value="editing.Title" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="会议日期" @bind-Date="meetingDateValue" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField Label="时长(分钟)" @bind-Value="editing.DurationMinutes" Min="1" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="会议地点" @bind-Value="editing.Location" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="参会人员" @bind-Value="editing.Attendees" Placeholder="用逗号分隔" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect Label="状态" @bind-Value="editing.Status" T="string">
                                    <MudSelectItem T="string" Value="@("已安排")">已安排</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("进行中")">进行中</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("已结束")">已结束</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("已取消")">已取消</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="会议议程" @bind-Value="editing.Agenda" Multiline="true" Rows="3" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="会议记录" @bind-Value="editing.Notes" Multiline="true" Rows="4" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="行动项" @bind-Value="editing.ActionItems" Multiline="true" Rows="3" Placeholder="每行一个行动项，格式: 事项 - 负责人 - 截止日期" />
                            </MudItem>
                        </MudGrid>
                        <div class="mt-4">
                            <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(!_isFormValid)" Variant="Variant.Filled">保存</MudButton>
                            <MudButton Color="Color.Default" OnClick="CancelForm" Class="ml-2">取消</MudButton>
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private List<MeetingNote> notes = new();
    private MeetingNote editing = new();
    private bool showForm;
    private MudForm _form = default!;
    private bool _isFormValid;
    private string? filterStatus;

    private DateTime? meetingDateValue;

    protected override async Task OnInitializedAsync() => await LoadNotes();

    private async Task LoadNotes() => notes = await MeetingSvc.GetNotesAsync(filterStatus);

    private static Color GetStatusColor(string status) => status switch
    {
        "已安排" => Color.Info,
        "进行中" => Color.Warning,
        "已结束" => Color.Success,
        _ => Color.Default
    };

    private void StartAdd()
    {
        editing = new MeetingNote { MeetingDate = DateTime.UtcNow, Status = "已安排", DurationMinutes = 30 };
        meetingDateValue = editing.MeetingDate;
        showForm = true;
    }

    private void StartEdit(MeetingNote note)
    {
        editing = new MeetingNote
        {
            Id = note.Id, Title = note.Title, MeetingDate = note.MeetingDate,
            DurationMinutes = note.DurationMinutes, Attendees = note.Attendees,
            Agenda = note.Agenda, Notes = note.Notes, ActionItems = note.ActionItems,
            Location = note.Location, Status = note.Status, MemberId = note.MemberId
        };
        meetingDateValue = note.MeetingDate;
        showForm = true;
    }

    private void CancelForm() => showForm = false;

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_isFormValid) return;
        try
        {
            if (meetingDateValue.HasValue) editing.MeetingDate = meetingDateValue.Value;
            if (editing.Id > 0)
            {
                await MeetingSvc.UpdateAsync(editing);
                Snackbar.Add("会议记录已更新", Severity.Success);
            }
            else
            {
                await MeetingSvc.AddAsync(editing);
                Snackbar.Add("会议已创建", Severity.Success);
            }
            showForm = false;
            await LoadNotes();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task Delete(long id)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("确认删除");
        var result = await dialog.Result;
        if (result.Canceled) return;

        try
        {
            await MeetingSvc.DeleteAsync(id);
            await LoadNotes();
            Snackbar.Add("会议已删除", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
        }
    }
}