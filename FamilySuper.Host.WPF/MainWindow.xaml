<Window x:Class="FamilySuper.Host.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FamilySuper.Host.WPF"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        mc:Ignorable="d" 
        Title="AI家庭超级管家" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#f5f5f7"
        StateChanged="OnStateChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2d2d30" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Image Source="wwwroot/logo.png" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="家庭超级管家" Foreground="White" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>
                <Button Content="最小化到托盘" Click="OnMinimizeToTray" Background="Transparent"
                        Foreground="#cccccc" BorderBrush="#555" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="退出" Click="OnExitClick" Background="Transparent"
                        Foreground="#ff6666" BorderBrush="#555" Padding="12,4"/>
            </StackPanel>
        </Border>

        <blazor:BlazorWebView Grid.Row="1"
                              x:Name="blazorWebView"
                              HostPage="wwwroot/index.html">
            <blazor:BlazorWebView.RootComponents>
                <blazor:RootComponent Selector="#app"
                                      ComponentType="{x:Type local:BlazorApp}" />
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>
    </Grid>
</Window>
